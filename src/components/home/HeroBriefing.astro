---
import { getCollection } from 'astro:content';

const allVotes = await getCollection('votes');
const allPersonnes = await getCollection('personnes');

// Sort votes by date descending
const recentVotes = [...allVotes]
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);

const totalDeputes = allPersonnes.length;
const totalVotes = allVotes.length;

// Count groups
const groups = new Map<string, number>();
for (const p of allPersonnes) {
  const g = p.data.groupe_parlementaire || 'NI';
  groups.set(g, (groups.get(g) || 0) + 1);
}
const topGroups = [...groups.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);
---

<section class="py-10 border-b border-gris-chaud">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="font-mono text-[11px] uppercase tracking-[2px] text-bleu-rep mb-2">● L'Assemblée en bref</div>
    <div class="font-display text-[15px] italic text-gris-clair mb-6">17e législature · {totalDeputes} députés</div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8">
      <!-- Main: site introduction + last votes -->
      <div class="lg:border-r lg:border-gris-chaud lg:pr-8 animate-fade-in-up">
        <h1 class="font-display text-4xl font-black leading-tight mb-4 tracking-tight">
          Suivez l'activité parlementaire en toute transparence
        </h1>

        <p class="text-[17px] leading-relaxed text-gris-texte mb-5">
          Citoyens.ai rassemble les données publiques de l'Assemblée nationale pour les rendre accessibles : profils des {totalDeputes} députés, votes en séance, dossiers législatifs et contenus pédagogiques.
        </p>

        <!-- Last 3 votes -->
        <div class="bg-blanc border border-gris-chaud rounded-lg p-4">
          <h4 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-3">Derniers scrutins publics</h4>
          <div class="flex flex-col gap-2">
            {recentVotes.map(vote => {
              const isAdopte = vote.data.resultat === 'adopte';
              return (
                <div class="flex items-center gap-2.5 text-[13px]">
                  <span class={`w-2 h-2 rounded-full shrink-0 ${isAdopte ? 'bg-vert' : 'bg-rouge-doux'}`}></span>
                  <span class="font-semibold text-noir flex-1 min-w-0 truncate">{vote.data.intitule}</span>
                  <span class={`text-xs font-mono shrink-0 ${isAdopte ? 'text-vert' : 'text-rouge-doux'}`}>
                    {isAdopte ? 'Adopté' : 'Rejeté'}
                  </span>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Sidebar: key numbers -->
      <div class="animate-fade-in-up delay-200">
        <h3 class="font-display text-lg font-bold mb-4 pb-2 border-b-2 border-noir">
          Chiffres clés
        </h3>

        <div class="grid grid-cols-2 gap-3 mb-5">
          <div class="bg-blanc border border-gris-chaud rounded-lg p-3 text-center">
            <div class="font-mono text-2xl font-medium text-bleu-rep">{totalDeputes}</div>
            <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-1">Députés</div>
          </div>
          <div class="bg-blanc border border-gris-chaud rounded-lg p-3 text-center">
            <div class="font-mono text-2xl font-medium text-bleu-rep">{groups.size}</div>
            <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-1">Groupes</div>
          </div>
          <div class="bg-blanc border border-gris-chaud rounded-lg p-3 text-center">
            <div class="font-mono text-2xl font-medium text-bleu-rep">{totalVotes}</div>
            <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-1">Scrutins</div>
          </div>
          <div class="bg-blanc border border-gris-chaud rounded-lg p-3 text-center">
            <div class="font-mono text-2xl font-medium text-bleu-rep">8</div>
            <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-1">Vidéos</div>
          </div>
        </div>

        <h4 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-3">Principaux groupes</h4>
        {topGroups.map(([g, count]) => (
          <div class="flex justify-between items-center py-1.5 border-b border-gris-chaud last:border-0 text-sm">
            <span class="font-semibold">{g}</span>
            <span class="font-mono text-gris-clair">{count} députés</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
