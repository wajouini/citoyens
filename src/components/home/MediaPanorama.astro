---
// Replaced: was hardcoded media comparisons. Now shows educational "Comprendre" section.
const comprendrePages = [
  {
    icone: '🏛️',
    titre: "L'Assemblée nationale",
    description: '577 députés, commissions, parcours d\'une loi : le fonctionnement de la chambre basse.',
    href: '/comprendre/assemblee-nationale',
  },
  {
    icone: '⚡',
    titre: 'Le 49.3 expliqué',
    description: 'L\'article 49 alinéa 3 de la Constitution : un outil controversé pour faire passer une loi sans vote.',
    href: '/comprendre/49-3',
  },
  {
    icone: '🗳️',
    titre: 'Motion de censure',
    description: 'Comment l\'Assemblée peut renverser le gouvernement. Historique et mécanismes.',
    href: '/comprendre/motion-de-censure',
  },
  {
    icone: '📜',
    titre: 'La navette parlementaire',
    description: 'PJL, PPL, commission, hémicycle, CMP : le parcours complet d\'un texte de loi.',
    href: '/comprendre/navette-parlementaire',
  },
  {
    icone: '🔍',
    titre: 'La HATVP',
    description: 'La Haute Autorité pour la transparence : déclarations de patrimoine, d\'intérêts et déontologie.',
    href: '/comprendre/hatvp',
  },
  {
    icone: '👥',
    titre: 'Les groupes parlementaires',
    description: 'EPR, RN, LFI-NFP, SOC... Qui sont les groupes de la 17e législature ?',
    href: '/comprendre/groupes-parlementaires',
  },
];
---

<section class="max-w-[1280px] mx-auto px-6">
  <div class="flex items-center gap-3 mt-10 mb-6">
    <h2 class="font-display text-2xl font-black whitespace-nowrap">Comprendre la politique</h2>
    <div class="flex-1 h-0.5 bg-noir"></div>
    <span class="font-mono text-xs text-gris-clair whitespace-nowrap">Guides pédagogiques</span>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
    {comprendrePages.map((item, i) => (
      <a
        href={item.href}
        class={`bg-blanc border border-gris-chaud rounded-lg p-5 flex gap-4 transition-all duration-300 cursor-pointer hover:-translate-y-0.5 hover:shadow-md hover:border-bleu-rep no-underline text-noir animate-fade-in-up delay-${(i % 3) + 1}00`}
      >
        <div class="w-10 h-10 bg-bleu-clair rounded-lg flex items-center justify-center text-xl shrink-0">
          {item.icone}
        </div>
        <div>
          <h3 class="font-display text-[15px] font-bold mb-1">{item.titre}</h3>
          <p class="text-[13px] text-gris-texte leading-relaxed">{item.description}</p>
        </div>
      </a>
    ))}
  </div>
</section>
