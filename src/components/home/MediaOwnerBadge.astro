---
interface Props {
  groupe_media?: {
    nom: string;
    proprietaire: string;
    type_proprietaire: string;
    orientation: string;
  } | null;
  orientation_source?: string | null;
  compact?: boolean;
}

const { groupe_media, orientation_source, compact = false } = Astro.props;

const typeStyles: Record<string, { bg: string; text: string; label: string }> = {
  milliardaire: { bg: 'bg-rouge-doux/10', text: 'text-rouge-doux', label: '💰' },
  cooperative: { bg: 'bg-vert/10', text: 'text-vert', label: '🤝' },
  etat: { bg: 'bg-bleu-clair', text: 'text-bleu-rep', label: '🏛' },
  fondation: { bg: 'bg-green-50', text: 'text-vert', label: '🛡' },
  employes: { bg: 'bg-green-50', text: 'text-vert', label: '👥' },
  independant: { bg: 'bg-green-50', text: 'text-vert', label: '✊' },
  famille: { bg: 'bg-orange/10', text: 'text-orange', label: '👨‍👩‍👧' },
};

const orientationColors: Record<string, string> = {
  'extreme-gauche': 'bg-red-700',
  'gauche': 'bg-red-500',
  'centre-gauche': 'bg-rose-400',
  'centre': 'bg-gray-400',
  'centre-droit': 'bg-blue-400',
  'droite': 'bg-blue-600',
  'extreme-droite': 'bg-blue-900',
  'variable': 'bg-gray-300',
};

const tp = groupe_media?.type_proprietaire || '';
const style = typeStyles[tp] || typeStyles['independant'];
const orient = orientation_source || groupe_media?.orientation || '';
const orientDot = orientationColors[orient] || 'bg-gray-300';
---

{groupe_media ? (
  <div class="relative inline-flex items-center group/badge">
    <span class={`w-2.5 h-2.5 rounded-full ${orientDot} cursor-help border border-white shadow-sm ring-1 ring-black/5`}></span>
    
    {/* Tooltip */}
    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 opacity-0 group-hover/badge:opacity-100 pointer-events-none transition-opacity z-50 whitespace-nowrap">
      <div class={`flex flex-col gap-0.5 px-2 py-1.5 rounded-lg shadow-lg text-[10px] font-mono leading-tight bg-white border border-gray-200`}>
        <div class="flex items-center gap-1.5">
          <span class="font-bold text-gray-700">Propriétaire:</span>
          <span class={`${style.text} font-semibold flex items-center gap-0.5`}>
            {style.label} {groupe_media.proprietaire}
          </span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="font-bold text-gray-700">Orientation:</span>
          <span class="flex items-center gap-1">
            <span class={`w-1.5 h-1.5 rounded-full ${orientDot}`}></span>
            {groupe_media.orientation}
          </span>
        </div>
      </div>
      {/* Tooltip arrow */}
      <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-white border-b border-r border-gray-200 rotate-45"></div>
    </div>
  </div>
) : orient ? (
  <div class="relative inline-flex items-center group/badge">
    <span class={`w-2.5 h-2.5 rounded-full ${orientDot} cursor-help border border-white shadow-sm ring-1 ring-black/5`}></span>
    
    {/* Tooltip */}
    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 opacity-0 group-hover/badge:opacity-100 pointer-events-none transition-opacity z-50 whitespace-nowrap">
      <div class="px-2 py-1.5 rounded-lg shadow-lg text-[10px] font-mono bg-white border border-gray-200">
        <div class="flex items-center gap-1.5">
          <span class="font-bold text-gray-700">Orientation:</span>
          <span class="flex items-center gap-1">
            <span class={`w-1.5 h-1.5 rounded-full ${orientDot}`}></span>
            {orient}
          </span>
        </div>
      </div>
      <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-white border-b border-r border-gray-200 rotate-45"></div>
    </div>
  </div>
) : null}
