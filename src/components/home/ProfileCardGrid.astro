---
import { getCollection } from 'astro:content';
import ProfileCard from './ProfileCard.astro';

const allPersonnes = await getCollection('personnes');
// Show top 4 by participation rate (data-driven, interesting selection)
const withParticipation = allPersonnes
  .filter(p => p.data.taux_participation != null && p.data.taux_participation > 0)
  .sort((a, b) => (b.data.taux_participation || 0) - (a.data.taux_participation || 0));
const trending = withParticipation.slice(0, 4);
const totalDeputes = allPersonnes.filter(p => p.data.role === 'depute').length;

// Count groups
const groups = new Map<string, number>();
for (const p of allPersonnes) {
  const g = p.data.groupe_parlementaire || 'NI';
  groups.set(g, (groups.get(g) || 0) + 1);
}
const nbGroups = groups.size;
---

<section class="max-w-[1280px] mx-auto px-6">
  <div class="flex items-center gap-3 mt-10 mb-6">
    <h2 class="font-display text-2xl font-black whitespace-nowrap">Députés les plus actifs</h2>
    <div class="flex-1 h-0.5 bg-noir"></div>
    <span class="font-mono text-xs text-gris-clair whitespace-nowrap">
      {totalDeputes} députés · {nbGroups} groupes
    </span>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
    {trending.map((p, i) => (
      <ProfileCard
        slug={p.data.slug}
        nom={p.data.nom}
        prenom={p.data.prenom}
        nom_complet={p.data.nom_complet}
        role={p.data.role}
        parti={p.data.parti}
        circonscription={p.data.circonscription}
        departement={p.data.departement}
        bio_courte={p.data.bio_courte}
        photo_url={p.data.photo_url}
        taux_participation={p.data.taux_participation}
        score_loyaute={p.data.score_loyaute}
        delay={i + 1}
      />
    ))}
  </div>

  <div class="text-center mb-10">
    <a href="/fiche" class="inline-flex items-center gap-2 text-sm font-semibold text-bleu-rep hover:underline no-underline">
      Voir tous les {totalDeputes} députés →
    </a>
  </div>
</section>
