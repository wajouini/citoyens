---
import { getCollection } from 'astro:content';

const allDossiers = await getCollection('dossiers');
---

<section class="max-w-[1280px] mx-auto px-6">
  <div class="flex items-center gap-3 mt-10 mb-6">
    <h2 class="font-display text-2xl font-black whitespace-nowrap">Dossiers de fond</h2>
    <div class="flex-1 h-0.5 bg-noir"></div>
    <span class="font-mono text-xs text-gris-clair whitespace-nowrap">Suivi dans la durée</span>
  </div>

  {allDossiers.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
      {allDossiers.map((d, i) => (
        <a
          href={`/dossiers/${d.id}`}
          class={`bg-blanc border border-gris-chaud rounded-lg p-6 flex gap-5 transition-all duration-300 cursor-pointer hover:-translate-y-0.5 hover:shadow-md hover:border-bleu-rep no-underline text-noir animate-fade-in-up delay-${i + 1}00`}
        >
          <div class="w-12 h-12 bg-bleu-clair rounded-lg flex items-center justify-center text-[22px] shrink-0">
            {d.data.icone}
          </div>
          <div class="flex-1">
            <h3 class="font-display text-[17px] font-bold mb-1.5">{d.data.titre}</h3>
            <p class="text-[13px] text-gris-texte leading-relaxed mb-2.5">{d.data.description}</p>
            <div class="flex items-center gap-2">
              <div class="flex-1 h-[3px] bg-gris-chaud rounded-full">
                <div class="h-full bg-bleu-rep rounded-full" style={`width:${d.data.progression}%`}></div>
              </div>
              <span class="font-mono text-[11px] text-gris-clair whitespace-nowrap">{d.data.etape_label}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="bg-blanc border border-gris-chaud rounded-lg p-8 text-center mb-10">
      <p class="text-gris-texte">Les dossiers de fond arrivent bientôt.</p>
    </div>
  )}
</section>
