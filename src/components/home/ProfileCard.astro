---
import { getInitials } from '../../utils/format';
import { roleLabels } from '../../utils/colors';

interface Props {
  slug: string;
  nom: string;
  prenom: string;
  nom_complet: string;
  role: string;
  parti?: { nom: string; sigle: string; couleur?: string };
  circonscription?: string;
  departement?: string;
  bio_courte: string;
  photo_url?: string;
  taux_participation?: number | null;
  score_loyaute?: number | null;
  delay?: number;
}

const {
  slug, nom, prenom, nom_complet, role, parti,
  circonscription, departement, photo_url,
  taux_participation, score_loyaute,
  delay = 0,
} = Astro.props;

const initials = getInitials(prenom, nom);
const roleLabel = roleLabels[role] || role;

const borderTopColor = {
  depute: 'before:bg-bleu-rep',
  senateur: 'before:bg-rouge-rep',
  journaliste: 'before:bg-orange',
  editorialiste: 'before:bg-orange',
  ministre: 'before:bg-bleu-rep',
}[role] || 'before:bg-gris-clair';

const avatarBg = parti?.couleur || '#6B7280';
---

<a
  href={`/fiche/${slug}`}
  class:list={[
    'block bg-blanc border border-gris-chaud rounded-lg p-5 transition-all duration-300 cursor-pointer',
    'relative overflow-hidden no-underline text-noir',
    'hover:-translate-y-1 hover:shadow-lg hover:border-bleu-rep',
    'before:content-[""] before:absolute before:top-0 before:left-0 before:right-0 before:h-[3px]',
    borderTopColor,
    'animate-fade-in-up',
    delay > 0 && `delay-${delay}00`,
  ]}
>
  <!-- Header -->
  <div class="flex items-center gap-3 mb-3.5">
    {photo_url ? (
      <img
        src={photo_url}
        alt={nom_complet}
        class="w-12 h-12 rounded-full object-cover shrink-0"
        loading="lazy"
        onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
      />
      <div
        class="w-12 h-12 rounded-full items-center justify-center font-display text-lg font-bold shrink-0 hidden"
        style={`background: ${avatarBg}20; color: ${avatarBg}`}
      >
        {initials}
      </div>
    ) : (
      <div
        class="w-12 h-12 rounded-full flex items-center justify-center font-display text-lg font-bold shrink-0"
        style={`background: ${avatarBg}20; color: ${avatarBg}`}
      >
        {initials}
      </div>
    )}
    <div>
      <div class="font-bold text-[15px] leading-tight">{nom_complet}</div>
      <div class="text-xs text-gris-clair">
        {roleLabel}{parti ? ` · ${parti.sigle}` : ''}{departement ? ` · ${departement}` : ''}
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 gap-2 mb-2">
    <div class="bg-creme rounded p-2 text-center">
      <div class="font-mono text-lg font-medium text-noir">
        {taux_participation != null ? `${Math.round(taux_participation)}%` : '—'}
      </div>
      <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-0.5">Participation</div>
    </div>
    <div class="bg-creme rounded p-2 text-center">
      <div class="font-mono text-lg font-medium text-noir">
        {score_loyaute != null ? `${Math.round(score_loyaute)}%` : '—'}
      </div>
      <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-0.5">Avec son groupe</div>
    </div>
  </div>

  <!-- Participation bar -->
  {taux_participation != null && (
    <div class="h-1 bg-gris-chaud rounded-full overflow-hidden mt-2">
      <div
        class="h-full rounded-full transition-all duration-1000 bg-bleu-rep"
        style={`width: ${Math.min(taux_participation, 100)}%`}
      ></div>
    </div>
  )}
</a>
