---
interface Props {
  items: any[];
  generatedAt?: string;
  derniereMaj?: string;
  filDate?: string;
}

const { items, generatedAt, derniereMaj, filDate } = Astro.props;

/** Returns time label: "14:30" today, "Hier" yesterday, "28 fév" older */
function formatItemHeure(isoDate: string | undefined, heure: string): string {
  if (!isoDate) return heure;
  const tz = 'Europe/Paris';
  const d = new Date(isoDate);
  if (isNaN(d.getTime())) return heure;
  const itemDay  = d.toLocaleDateString('fr-FR', { timeZone: tz, year: 'numeric', month: '2-digit', day: '2-digit' });
  const now      = new Date();
  const todayDay = now.toLocaleDateString('fr-FR', { timeZone: tz, year: 'numeric', month: '2-digit', day: '2-digit' });
  if (itemDay === todayDay) return heure;
  const prev     = new Date(now); prev.setDate(prev.getDate() - 1);
  const yestDay  = prev.toLocaleDateString('fr-FR', { timeZone: tz, year: 'numeric', month: '2-digit', day: '2-digit' });
  if (itemDay === yestDay) return `Hier ${heure}`;
  return `${d.toLocaleDateString('fr-FR', { timeZone: tz, day: 'numeric', month: 'short' })} ${heure}`;
}

const rubriqueStyle: Record<string, { label: string; color: string }> = {
  // Politique
  conflit:      { label: 'Conflit',      color: 'text-red-700' },
  diplomatie:   { label: 'Diplomatie',   color: 'text-sky-700' },
  elections:    { label: 'Élections',    color: 'text-bleu-rep' },
  parlement:    { label: 'Parlement',    color: 'text-bleu-rep' },
  gouvernement: { label: 'Gouvernement', color: 'text-bleu-rep' },
  // Tech & IA
  ia:           { label: 'IA',           color: 'text-indigo-700' },
  spatial:      { label: 'Spatial',      color: 'text-violet-700' },
  medecine:     { label: 'Médecine',     color: 'text-emerald-700' },
  robotique:    { label: 'Robotique',    color: 'text-slate-700' },
  electronique: { label: 'Électronique', color: 'text-blue-700' },
  cybersec:     { label: 'Cybersec',     color: 'text-orange-700' },
  science:      { label: 'Science',      color: 'text-vert' },
  // Économie
  macro:        { label: 'Macro',        color: 'text-orange' },
  taxe:         { label: 'Taxe',         color: 'text-orange' },
  industrie:    { label: 'Industrie',    color: 'text-amber-700' },
  automobile:   { label: 'Automobile',   color: 'text-zinc-700' },
  transport:    { label: 'Transport',    color: 'text-cyan-700' },
  energie:      { label: 'Énergie',      color: 'text-yellow-700' },
  immobilier:   { label: 'Immobilier',   color: 'text-stone-700' },
  travail:        { label: 'Travail',        color: 'text-rouge-doux' },
  salaire:        { label: 'Salaire',        color: 'text-rouge-doux' },
  investissement: { label: 'Investissement', color: 'text-amber-700' },
  ecologie:       { label: 'Écologie',       color: 'text-vert' },
  // Tech (supplémentaires)
  architecture: { label: 'Architecture', color: 'text-teal-700' },
  // Société
  justice:      { label: 'Justice',      color: 'text-purple-700' },
  education:    { label: 'Éducation',    color: 'text-blue-700' },
  sante:        { label: 'Santé',        color: 'text-teal-700' },
  logement:     { label: 'Logement',     color: 'text-amber-700' },
  droits:         { label: 'Droits',         color: 'text-rose-700' },
  discrimination: { label: 'Discrimination', color: 'text-rose-800' },
  faits:          { label: 'Faits divers',   color: 'text-zinc-600' },
  // Autres
  culture:      { label: 'Culture',      color: 'text-amber-700' },
  sport:        { label: 'Sport',        color: 'text-lime-700' },
  general:      { label: 'Général',      color: 'text-gris-clair' },
  // Legacy fallbacks
  politique:    { label: 'Politique',    color: 'text-bleu-rep' },
  economie:     { label: 'Économie',     color: 'text-orange' },
  tech:         { label: 'Tech',         color: 'text-purple-700' },
  societe:      { label: 'Société',      color: 'text-rouge-doux' },
  international:{ label: 'International',color: 'text-sky-700' },
};

const filDateFormatted = filDate
  ? new Date(filDate + 'T00:00:00').toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short' })
  : null;
---

<section class="mb-8" id="fil-preview">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-2">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-vert opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-vert"></span>
      </span>
      <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-noir">Fil continu</span>
    </div>
    <div class="flex items-center gap-3">
      {(derniereMaj || generatedAt) && (
        <span
          class="font-mono text-[10px] text-gris-clair"
          id="fil-preview-timestamp"
          data-ts={derniereMaj || generatedAt}
        >
          MAJ {new Date(derniereMaj || generatedAt!).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
        </span>
      )}
      <a href="/fil" class="font-mono text-[11px] text-bleu-rep no-underline hover:underline font-semibold">
        Voir tout →
      </a>
    </div>
  </div>

  {filDate && (
    <div
      class="hidden font-mono text-[10px] text-orange bg-orange/10 rounded-lg px-3 py-1.5 mb-3 text-center"
      id="fil-date-banner"
      data-fil-date={filDate}
    >
      Édition du {filDateFormatted}
    </div>
  )}

  <div class="flex flex-col gap-0 border border-gris-chaud rounded-lg overflow-hidden bg-blanc" id="fil-items">
    {items.slice(0, 6).map((item: any) => {
      const style = rubriqueStyle[item.rubrique] ?? rubriqueStyle.general;
      const itemUrl = item.url || item.source_url;
      const itemTitle = item.titre || item.texte;
      return (
        <div class="flex gap-3 px-4 py-3 border-b border-gris-chaud last:border-0">
          <div class="shrink-0 pt-0.5">
            <span class="font-mono text-[11px] font-bold text-gris-clair">{formatItemHeure(item.isoDate, item.heure)}</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-0.5">
              <span class={`font-mono text-[9px] font-bold uppercase tracking-wider ${style.color}`}>
                {style.label}
              </span>
              <a
                href={itemUrl || '#'}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-[9px] text-gris-clair no-underline hover:text-bleu-rep transition-colors"
              >
                {item.source} ↗
              </a>
            </div>
            {itemUrl ? (
              <a
                href={itemUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="block text-[13px] text-noir leading-snug no-underline hover:text-bleu-rep transition-colors line-clamp-2"
              >
                {itemTitle}
              </a>
            ) : (
              <p class="text-[13px] text-noir leading-snug line-clamp-2">{itemTitle}</p>
            )}
          </div>
        </div>
      );
    })}
  </div>
</section>

<script>
  // Show stale-date banner if fil date isn't today
  const banner = document.getElementById('fil-date-banner');
  if (banner) {
    const filDate = banner.getAttribute('data-fil-date');
    if (filDate) {
      const today = new Date().toISOString().slice(0, 10);
      if (filDate !== today) banner.classList.remove('hidden');
    }
  }

  // Update relative timestamp every minute
  function updateTs() {
    const el = document.getElementById('fil-preview-timestamp');
    if (!el) return;
    const ts = el.getAttribute('data-ts');
    if (!ts) return;
    const diff = Date.now() - new Date(ts).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) el.textContent = "MAJ à l'instant";
    else if (mins < 60) el.textContent = `MAJ il y a ${mins}min`;
    else el.textContent = `MAJ il y a ${Math.floor(mins / 60)}h`;
  }
  updateTs();
  setInterval(updateTs, 60_000);
</script>
