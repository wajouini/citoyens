---
const navItems = [
  { label: 'Accueil', href: '/' },
  { label: 'Décryptages', href: '/decodage' },
  { label: 'Dossiers', href: '/dossiers' },
  { label: 'Députés', href: '/fiche' },
  { label: 'Comprendre', href: '/comprendre' },
];

const currentPath = Astro.url.pathname;
---

<!-- Top Bar -->
<div class="bg-bleu-rep text-white py-1.5 text-[11px] tracking-wider uppercase font-medium">
  <div class="max-w-[1280px] mx-auto px-6 flex justify-between items-center">
    <span class="opacity-70">Initiative citoyenne indépendante · Code source ouvert · Zéro publicité</span>
    <span class="opacity-70">Données : data.gouv.fr · Assemblée nationale</span>
  </div>
</div>

<!-- Main Header -->
<header class="bg-blanc border-b-[3px] border-noir py-5 sticky top-0 z-50">
  <div class="max-w-[1280px] mx-auto px-6 flex justify-between items-center">
    <div class="flex items-center">
      <a href="/" class="flex items-baseline gap-1 no-underline text-noir">
        <span class="font-display text-[32px] font-black tracking-tighter">citoyens</span>
        <span class="font-mono text-sm font-medium text-bleu-rep bg-bleu-clair px-1.5 py-0.5 rounded">
          .ai
        </span>
      </a>
      <span class="text-[11px] uppercase tracking-[2px] text-gris-clair ml-4 border-l border-gris-chaud pl-4 hidden md:inline">
        Le journal citoyen de la politique
      </span>
    </div>

    <nav class="hidden lg:flex items-center gap-1.5">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'text-[13px] font-semibold no-underline px-3 py-1.5 rounded transition-colors uppercase tracking-wider',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'bg-bleu-rep text-white'
              : 'text-gris-texte hover:bg-creme hover:text-noir',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
