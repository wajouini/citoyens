---
const explorerLinks = [
  { label: 'Tous les députés', href: '/fiche' },
  { label: 'Scrutins récents', href: '/#votes' },
  { label: 'Médias', href: '/media' },
  { label: 'Dossiers de fond', href: '/dossiers' },
];

const comprendreLinks = [
  { label: "L'Assemblée nationale", href: '/comprendre/assemblee-nationale' },
  { label: 'Le 49.3 expliqué', href: '/comprendre/49-3' },
  { label: 'Motion de censure', href: '/comprendre/motion-de-censure' },
  { label: 'Navette parlementaire', href: '/comprendre/navette-parlementaire' },
  { label: 'La HATVP', href: '/comprendre/hatvp' },
  { label: 'Groupes parlementaires', href: '/comprendre/groupes-parlementaires' },
];

const aProposLinks = [
  { label: 'À propos', href: '/a-propos' },
  { label: 'Méthodologie', href: '/methodologie' },
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Code source (GitHub)', href: 'https://github.com/boredgeeksociety/citoyens' },
];
---

<footer class="bg-noir text-white pt-12 pb-6 mt-16">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-10">
      <!-- Brand -->
      <div>
        <span class="font-display text-[28px] font-black">
          citoyens<span class="text-bleu-clair">.ai</span>
        </span>
        <p class="text-sm text-white/50 leading-relaxed mt-3 max-w-xs">
          Initiative citoyenne indépendante. Aucune publicité, aucun financement partisan. Code source ouvert. L'IA au service de la transparence démocratique.
        </p>
        <a href="/soutenir" class="inline-block mt-4 bg-bleu-rep text-white font-semibold text-[13px] no-underline py-2 px-4 rounded-lg hover:bg-bleu-rep/90 transition-colors">
          Soutenir le projet
        </a>
      </div>

      <!-- Explorer -->
      <div>
        <h4 class="text-[11px] uppercase tracking-[2px] text-white/40 mb-4">Explorer</h4>
        {explorerLinks.map(link => (
          <a href={link.href} class="block text-white/70 no-underline text-sm py-1 hover:text-white transition-colors">
            {link.label}
          </a>
        ))}
      </div>

      <!-- Comprendre -->
      <div>
        <h4 class="text-[11px] uppercase tracking-[2px] text-white/40 mb-4">Comprendre</h4>
        {comprendreLinks.map(link => (
          <a href={link.href} class="block text-white/70 no-underline text-sm py-1 hover:text-white transition-colors">
            {link.label}
          </a>
        ))}
      </div>

      <!-- À propos -->
      <div>
        <h4 class="text-[11px] uppercase tracking-[2px] text-white/40 mb-4">À propos</h4>
        {aProposLinks.map(link => (
          <a href={link.href} class="block text-white/70 no-underline text-sm py-1 hover:text-white transition-colors" target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener' : undefined}>
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/10 pt-5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-white/30">
      <span>© 2026 Citoyens.ai · Association loi 1901 · Données : data.gouv.fr, Assemblée nationale</span>
      <div class="flex gap-3">
        <span class="px-2 py-0.5 border border-white/15 rounded font-mono text-[10px]">Open Source</span>
        <span class="px-2 py-0.5 border border-white/15 rounded font-mono text-[10px]">RGPD</span>
        <span class="px-2 py-0.5 border border-white/15 rounded font-mono text-[10px]">Zéro pub</span>
      </div>
    </div>
  </div>
</footer>
