---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MediaOwnerBadge from '../components/home/MediaOwnerBadge.astro';

const sujetsData = await import('../data/sujets-chauds.json').then(m => m.default).catch(() => null);

const sujetsActifs = sujetsData?.sujets_actifs || [];
const sujetsRefroidis = sujetsData?.sujets_refroidis || [];

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
};

const formatDateShort = (dateStr: string) => {
  try {
    const d = new Date(dateStr + 'T00:00:00');
    return d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
  } catch { return dateStr; }
};

const intensiteBadge: Record<string, { label: string; cls: string; icon: string }> = {
  brulant: { label: 'Brulant', cls: 'bg-rouge-doux text-white', icon: '🔥' },
  intense: { label: 'Intense', cls: 'bg-orange text-white', icon: '⚡' },
  en_montee: { label: 'En montée', cls: 'bg-amber-500 text-white', icon: '📈' },
};

const rubriqueStyle: Record<string, { label: string; color: string; bg: string }> = {
  politique: { label: 'Politique', color: 'text-bleu-rep', bg: 'bg-bleu-clair' },
  economie: { label: 'Économie', color: 'text-orange', bg: 'bg-orange/10' },
  tech: { label: 'Tech', color: 'text-purple-700', bg: 'bg-purple-50' },
  science: { label: 'Science', color: 'text-vert', bg: 'bg-green-50' },
  societe: { label: 'Société', color: 'text-rouge-doux', bg: 'bg-red-50' },
  culture: { label: 'Culture', color: 'text-amber-700', bg: 'bg-amber-50' },
  international: { label: 'International', color: 'text-sky-700', bg: 'bg-sky-50' },
  ia: { label: 'IA', color: 'text-indigo-700', bg: 'bg-indigo-50' },
};

const tonBadge: Record<string, { label: string; cls: string }> = {
  critique: { label: 'Critique', cls: 'bg-rouge-doux/10 text-rouge-doux' },
  factuel: { label: 'Factuel', cls: 'bg-bleu-clair text-bleu-rep' },
  alarmiste: { label: 'Alarmiste', cls: 'bg-orange/10 text-orange' },
  complaisant: { label: 'Complaisant', cls: 'bg-amber-50 text-amber-700' },
  neutre: { label: 'Neutre', cls: 'bg-gray-100 text-gris-texte' },
  engage: { label: 'Engagé', cls: 'bg-purple-50 text-purple-700' },
};

const sourceTypeBg: Record<string, string> = {
  investigation: 'border-l-orange',
  mainstream: 'border-l-bleu-rep',
  'fact-check': 'border-l-vert',
  etranger: 'border-l-purple-600',
  institutionnel: 'border-l-gris-clair',
};

const jsonLd = sujetsActifs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Sujets chauds — Citoyens.ai',
  description: 'Les sujets dont tout le monde parle, traités avec transparence et recul',
  datePublished: sujetsData?.date,
  publisher: { '@type': 'Organization', name: 'Citoyens.ai' },
} : undefined;
---

<BaseLayout title="Sujets chauds" description="Les sujets dont tout le monde parle — polémiques, crises, scandales — traités avec recul et transparence" jsonLd={jsonLd}>
  <Header />
  <main>
    {sujetsData ? (
      <div class="max-w-[1024px] mx-auto px-4 md:px-6">
        <!-- Header -->
        <div class="flex items-center gap-3 mb-8 md:mb-10 pt-8 md:pt-12">
          <div class="font-mono text-[11px] md:text-[12px] uppercase tracking-[2px] text-rouge-doux font-bold flex items-center gap-2">
            <span class="text-xl">🔥</span> Sujets chauds
          </div>
          <div class="flex-1 h-px bg-gris-chaud"></div>
          <div class="font-mono text-[10px] md:text-[11px] text-gris-clair">{sujetsData.date && formatDate(sujetsData.date)}</div>
        </div>

        <div class="max-w-[760px] mb-12">
          <p class="text-[16px] md:text-[18px] text-gris-texte leading-relaxed font-medium">
            Les sujets dont tout le monde parle en ce moment, traités avec le recul et la transparence Citoyens.ai.
            Pour chaque sujet : les faits, la chronologie, et l'analyse de la couverture médiatique.
          </p>
        </div>

        {/* ── SUJETS ACTIFS ── */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        {sujetsActifs.map((sujet: any, idx: number) => {
          const intensite = intensiteBadge[sujet.intensite] || intensiteBadge.intense;
          const rubrique = rubriqueStyle[sujet.rubrique] || rubriqueStyle.politique;
          return (
            <section class="bg-blanc border border-gris-chaud rounded-xl p-6 md:p-8 hover:shadow-md transition-shadow relative overflow-hidden" id={sujet.slug}>
              {/* Top Accent Line */}
              <div class={`absolute top-0 left-0 right-0 h-1.5 ${intensite.cls.split(' ')[0]}`}></div>
              
              {/* Badges */}
              <div class="flex items-center gap-2 mb-4 flex-wrap">
                <span class={`font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full ${intensite.cls}`}>
                  {intensite.icon} {intensite.label}
                </span>
                <span class={`font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full ${rubrique.bg} ${rubrique.color}`}>
                  {rubrique.label}
                </span>
                <span class="font-mono text-[9px] text-gris-clair ml-auto">
                  Depuis le {formatDateShort(sujet.premiere_apparition)}
                </span>
              </div>

              {/* Titre */}
              <h2 class="font-display text-[22px] md:text-[28px] font-black leading-tight text-noir mb-4">
                {sujet.titre}
              </h2>

              {/* Résumé */}
              <p class="text-[15px] leading-relaxed text-gris-texte mb-8">
                {sujet.resume}
              </p>

              <div class="space-y-8">
              {/* Chronologie */}
              {sujet.chronologie?.length > 0 && (
                <div>
                  <h3 class="font-mono text-[10px] uppercase tracking-[2px] text-noir mb-4 flex items-center gap-2">
                    <span class="text-sm">⏱</span> Chronologie
                  </h3>
                  <div class="relative pl-4 border-l-2 border-gris-chaud/50 space-y-4">
                    {sujet.chronologie.map((evt: any) => (
                      <div class="relative">
                        <span class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-blanc border-2 border-bleu-rep"></span>
                        <div class="flex items-baseline gap-2 mb-1">
                          <span class="font-mono text-[11px] font-bold text-bleu-rep shrink-0">{formatDateShort(evt.date)}</span>
                          {evt.source && <span class="font-mono text-[9px] text-gris-clair">via {evt.source}</span>}
                        </div>
                        <p class="text-[14px] text-noir leading-relaxed">{evt.texte}</p>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Couvertures médias */}
              {sujet.couvertures?.length > 0 && (
                <div>
                  <h3 class="font-mono text-[10px] uppercase tracking-[2px] text-noir mb-4 flex items-center gap-2">
                    <span class="text-sm">📰</span> Comment les médias en parlent
                  </h3>
                  <div class="flex flex-col gap-3">
                    {sujet.couvertures.map((c: any) => (
                      <a href={c.url} target="_blank" rel="noopener noreferrer"
                         class={`block p-4 rounded-lg border border-gris-chaud border-l-4 ${sourceTypeBg[c.type] || 'border-l-gris-clair'} bg-creme/30 no-underline hover:bg-blanc hover:shadow-sm transition-all group/card`}>
                        <div class="flex items-center gap-2 mb-2 flex-wrap">
                          <span class="font-mono text-[12px] font-bold text-noir">{c.source}</span>
                          {tonBadge[c.ton] && (
                            <span class={`text-[9px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded-full ${tonBadge[c.ton].cls}`}>
                              {tonBadge[c.ton].label}
                            </span>
                          )}
                          {c.groupe_media && <MediaOwnerBadge groupe_media={c.groupe_media} compact={true} />}
                        </div>
                        <p class="text-[14px] leading-snug text-noir font-semibold mb-1 group-hover/card:text-bleu-rep transition-colors">
                          {c.angle}
                        </p>
                        {c.citation_cle && (
                          <p class="text-[12px] text-gris-texte italic leading-relaxed mt-2 border-t border-gris-chaud/50 pt-2">
                            « {c.citation_cle} »
                          </p>
                        )}
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {/* Ce qu'on ne sait pas encore */}
              {sujet.ce_quon_ne_sait_pas?.length > 0 && (
                <div class="bg-orange/5 border border-orange/20 rounded-xl p-5">
                  <h4 class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-orange mb-3 flex items-center gap-2">
                    <span>❓</span> Ce qu'on ne sait pas encore
                  </h4>
                  <ul class="flex flex-col gap-2">
                    {sujet.ce_quon_ne_sait_pas.map((q: string) => (
                      <li class="flex items-start gap-2.5 text-[14px] text-noir leading-relaxed">
                        <span class="text-orange mt-1 shrink-0 text-xs">▸</span>
                        <span>{q}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* Sources */}
              {sujet.sources?.length > 0 && (
                <div class="pt-6 border-t border-gris-chaud/50">
                  <div class="flex flex-wrap gap-2">
                    {sujet.sources.map((src: any) => (
                      <a href={src.url} target="_blank" rel="noopener noreferrer"
                         class="inline-flex items-center gap-1.5 text-[11px] font-mono font-medium text-gris-texte bg-creme no-underline hover:text-bleu-rep hover:bg-bleu-clair/30 transition-colors border border-gris-chaud rounded-full px-3 py-1.5">
                        {src.groupe_media && <MediaOwnerBadge groupe_media={src.groupe_media} compact={true} />}
                        {src.nom} ↗
                      </a>
                    ))}
                  </div>
                </div>
              )}
              </div>
            </section>
          );
        })}
        </div>

        {/* ── SUJETS REFROIDIS ── */}
        {sujetsRefroidis.length > 0 && (
          <>
            <div class="h-px bg-gris-chaud mb-12"></div>
            <section class="mb-12 max-w-[760px] mx-auto">
              <h2 class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-gris-clair mb-6">Sujets refroidis</h2>
              <div class="flex flex-col gap-3">
                {sujetsRefroidis.map((s: any) => (
                  <div class="py-4 border-b border-gris-chaud/50 last:border-0 hover:bg-creme/50 rounded-lg px-2 -mx-2 transition-colors">
                    <div class="flex items-center gap-3 mb-1">
                      <span class="font-display text-[16px] font-bold text-gris-texte">{s.titre}</span>
                      <span class="font-mono text-[10px] text-gris-clair ml-auto">
                        Dernière MAJ : {formatDateShort(s.derniere_mise_a_jour)}
                      </span>
                    </div>
                    <p class="text-[14px] text-gris-clair leading-relaxed">{s.statut}</p>
                  </div>
                ))}
              </div>
            </section>
          </>
        )}

        {/* ── Meta ── */}
        {sujetsData.meta && (
          <div class="font-mono text-[10px] text-gris-clair text-center pb-10 border-t border-gris-chaud pt-6 max-w-[760px] mx-auto">
            {sujetsData.meta.nb_articles_analyses} articles analysés · {sujetsData.meta.modele}
          </div>
        )}
      </div>
    ) : (
      <div class="max-w-[760px] mx-auto px-4 md:px-5 py-24 text-center">
        <p class="text-gris-clair text-[16px] mb-4">Aucun sujet chaud pour le moment.</p>
        <a href="/" class="inline-block text-bleu-rep no-underline hover:underline font-semibold text-[15px]">Voir l'édition du matin</a>
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>
