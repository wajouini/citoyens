---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

const decryptageModules = import.meta.glob('../../data/decryptages/*.json', { eager: true });

interface DecryptageEntry {
  slug: string;
  titre: string;
  sous_titre: string;
  rubrique: string;
  date: string;
  sections_count: number;
}

const decryptages: DecryptageEntry[] = [];

for (const [, mod] of Object.entries(decryptageModules)) {
  const data = (mod as any).default;
  if (data?.slug && data?.titre) {
    decryptages.push({
      slug: data.slug,
      titre: data.titre,
      sous_titre: data.sous_titre || '',
      rubrique: data.rubrique || 'politique',
      date: data.date || '',
      sections_count: data.sections?.length || 0,
    });
  }
}

decryptages.sort((a, b) => b.date.localeCompare(a.date));

const rubriqueStyle: Record<string, { label: string; color: string; bg: string }> = {
  politique: { label: 'Politique', color: 'text-bleu-rep', bg: 'bg-bleu-clair' },
  economie: { label: 'Économie', color: 'text-orange', bg: 'bg-orange/10' },
  tech: { label: 'Tech', color: 'text-purple-700', bg: 'bg-purple-50' },
  science: { label: 'Science', color: 'text-vert', bg: 'bg-green-50' },
  societe: { label: 'Société', color: 'text-rouge-doux', bg: 'bg-red-50' },
  culture: { label: 'Culture', color: 'text-amber-700', bg: 'bg-amber-50' },
  international: { label: 'International', color: 'text-sky-700', bg: 'bg-sky-50' },
};
---

<BaseLayout title="Décryptages" description="Nos analyses de fond hebdomadaires — des articles longs pour comprendre les sujets complexes de l'actualité.">
  <Header />
  <main>
    <div class="max-w-[760px] mx-auto px-4 md:px-5 py-10">
      <h1 class="font-display text-[32px] md:text-[40px] font-black tracking-tight text-noir mb-2">Décryptages</h1>
      <p class="text-[15px] text-gris-texte mb-8">Analyses de fond hebdomadaires. 5-10 minutes de lecture pour comprendre les sujets complexes.</p>

      {decryptages.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-gris-clair text-[15px]">Le premier décryptage sera publié bientôt.</p>
          <p class="text-gris-clair text-[13px] mt-2">Chaque semaine, nous publions une analyse approfondie sur un sujet complexe.</p>
        </div>
      ) : (
        <div class="flex flex-col gap-6">
          {decryptages.map((d) => {
            const style = rubriqueStyle[d.rubrique] || rubriqueStyle.politique;
            return (
              <a href={`/decryptage/${d.slug}`}
                 class="block border-2 border-gris-chaud rounded-xl p-5 no-underline hover:border-bleu-rep hover:shadow-lg transition-all group">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${style.bg} ${style.color}`}>
                    {style.label}
                  </span>
                  <span class="font-mono text-[11px] text-gris-clair">
                    {new Date(d.date + 'T00:00:00').toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </span>
                </div>
                <h2 class="font-display text-[20px] md:text-[24px] font-black text-noir leading-tight mb-2 group-hover:text-bleu-rep transition-colors">
                  {d.titre}
                </h2>
                <p class="text-[14px] text-gris-texte leading-relaxed">{d.sous_titre}</p>
                <div class="mt-3 font-mono text-[10px] text-gris-clair">
                  {d.sections_count} sections · 5-10 min de lecture
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
