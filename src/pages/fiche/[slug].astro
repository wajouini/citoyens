---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { getInitials, formatDateShort } from '../../utils/format';
import { getCoherenceColor, roleLabels, getPartiColor } from '../../utils/colors';

export async function getStaticPaths() {
  const personnes = await getCollection('personnes');
  return personnes.map(p => ({
    params: { slug: p.data.slug },
    props: { personne: p.data },
  }));
}

const { personne } = Astro.props;
const initials = getInitials(personne.prenom, personne.nom);
const roleLabel = roleLabels[personne.role] || personne.role;
const isParliamentarian = personne.role === 'depute' || personne.role === 'senateur';
const partiColor = personne.parti?.couleur || getPartiColor(personne.parti?.sigle || '');

const votePositionStyles: Record<string, string> = {
  pour: 'bg-green-50 text-vert',
  contre: 'bg-red-50 text-rouge-doux',
  abstention: 'bg-yellow-50 text-orange',
  absent: 'bg-gray-100 text-gris-clair',
};

const votePositionLabels: Record<string, string> = {
  pour: 'Pour',
  contre: 'Contre',
  abstention: 'Abstention',
  absent: 'Absent',
};
---

<BaseLayout
  title={personne.nom_complet}
  description={personne.bio_courte}
>
  <Header />

  <main class="max-w-[1280px] mx-auto px-6 py-8">
    <!-- Breadcrumbs -->
    <nav class="text-xs text-gris-clair mb-6">
      <a href="/" class="hover:text-noir no-underline text-gris-clair">Accueil</a>
      <span class="mx-1.5">&rsaquo;</span>
      <a href="/" class="hover:text-noir no-underline text-gris-clair">Fiches</a>
      <span class="mx-1.5">&rsaquo;</span>
      <span class="text-noir">{personne.nom_complet}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-8">
      <!-- Sidebar -->
      <aside>
        <!-- Identity Card -->
        <div class="bg-blanc border border-gris-chaud rounded-lg p-6 mb-4">
          <div class="flex flex-col items-center text-center mb-4">
            <div
              class="w-20 h-20 rounded-full flex items-center justify-center font-display text-2xl font-bold mb-3"
              style={`background: ${partiColor}20; color: ${partiColor}`}
            >
              {initials}
            </div>
            <h1 class="font-display text-2xl font-black">{personne.nom_complet}</h1>
            <div class="text-sm text-gris-texte mt-1">
              {roleLabel}
              {personne.parti && (
                <span class="inline-flex items-center gap-1 ml-1">
                  &middot;
                  <span
                    class="inline-block w-2.5 h-2.5 rounded-full"
                    style={`background: ${partiColor}`}
                  ></span>
                  {personne.parti.nom}
                </span>
              )}
            </div>
            {personne.circonscription && (
              <div class="text-xs text-gris-clair mt-1">
                {personne.circonscription}{personne.departement ? ` \u00B7 ${personne.departement}` : ''}
              </div>
            )}
          </div>

          <p class="text-sm text-gris-texte leading-relaxed border-t border-gris-chaud pt-4">
            {personne.bio_courte}
          </p>
        </div>

        <!-- Key Stats (parliamentarians only) -->
        {isParliamentarian && (
          <div class="bg-blanc border border-gris-chaud rounded-lg p-6 mb-4">
            <h3 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-3">Chiffres cl&eacute;s</h3>
            <div class="grid grid-cols-2 gap-3">
              <div class="text-center">
                <div class="font-mono text-2xl font-medium text-bleu-rep">
                  {personne.taux_participation != null ? `${personne.taux_participation}%` : '\u2014'}
                </div>
                <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-1">Pr&eacute;sence</div>
              </div>
              <div class="text-center">
                <div class="font-mono text-2xl font-medium text-bleu-rep">{personne.questions_ecrites}</div>
                <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-1">Questions</div>
              </div>
              <div class="text-center">
                <div class="font-mono text-2xl font-medium text-bleu-rep">{personne.propositions_loi}</div>
                <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-1">Prop. de loi</div>
              </div>
              {personne.score_coherence != null && (
                <div class="text-center">
                  <div class="font-mono text-2xl font-medium" style={`color: ${getCoherenceColor(personne.score_coherence)}`}>
                    {personne.score_coherence}%
                  </div>
                  <div class="text-[10px] uppercase tracking-wider text-gris-clair mt-1">Coh&eacute;rence</div>
                </div>
              )}
            </div>
          </div>
        )}

        <!-- Commissions -->
        {personne.commissions.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-lg p-6 mb-4">
            <h3 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-3">Commissions</h3>
            <ul class="text-sm space-y-1.5 list-none p-0 m-0">
              {personne.commissions.map((c: string) => (
                <li class="flex items-start gap-2">
                  <span class="text-bleu-rep mt-0.5">&bull;</span>
                  {c}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Condamnations -->
        {personne.condamnations.length > 0 && (
          <div class="bg-blanc border border-rouge-doux/30 rounded-lg p-6 mb-4">
            <h3 class="text-[11px] uppercase tracking-[1.5px] text-rouge-doux mb-3">Condamnations & mises en examen</h3>
            <ul class="text-sm space-y-1.5 text-gris-texte list-none p-0 m-0">
              {personne.condamnations.map((c: string) => (
                <li class="flex items-start gap-2">
                  <span class="text-rouge-doux mt-0.5">&rlm;&#x26A0;</span>
                  {c}
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>

      <!-- Main Content -->
      <div>
        <!-- Bio longue -->
        {personne.bio_longue && (
          <section class="bg-blanc border border-gris-chaud rounded-lg p-6 mb-4">
            <h2 class="font-display text-xl font-bold mb-3 pb-2 border-b border-gris-chaud">Biographie</h2>
            <p class="text-[15px] text-gris-texte leading-relaxed">{personne.bio_longue}</p>
          </section>
        )}

        <!-- Parcours -->
        {personne.parcours.length > 0 && (
          <section class="bg-blanc border border-gris-chaud rounded-lg p-6 mb-4">
            <h2 class="font-display text-xl font-bold mb-4 pb-2 border-b border-gris-chaud">Parcours</h2>
            <div class="relative pl-6">
              <div class="absolute left-2 top-1 bottom-1 w-0.5 bg-gris-chaud"></div>
              {personne.parcours.map((entry: { periode: string; fonction: string }) => (
                <div class="relative mb-4 last:mb-0">
                  <div class="absolute -left-[18px] top-1 w-3 h-3 rounded-full border-2 border-bleu-rep bg-blanc"></div>
                  <div class="font-mono text-xs text-gris-clair mb-0.5">{entry.periode}</div>
                  <div class="text-sm font-medium">{entry.fonction}</div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Votes récents -->
        {personne.votes_recents.length > 0 && (
          <section class="bg-blanc border border-gris-chaud rounded-lg p-6 mb-4">
            <h2 class="font-display text-xl font-bold mb-4 pb-2 border-b border-gris-chaud">Votes r&eacute;cents</h2>
            <div class="space-y-0">
              {personne.votes_recents.map((vote: { date: string; intitule: string; position: string }) => (
                <div class="flex items-center gap-3 py-3 border-b border-gris-chaud last:border-0">
                  <span class={`shrink-0 text-xs font-semibold px-2 py-0.5 rounded ${votePositionStyles[vote.position] || ''}`}>
                    {votePositionLabels[vote.position] || vote.position}
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium truncate">{vote.intitule}</div>
                    <div class="text-xs text-gris-clair">{formatDateShort(vote.date)}</div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Coherence Score -->
        {personne.score_coherence != null && (
          <section class="bg-blanc border border-gris-chaud rounded-lg p-6 mb-4">
            <h2 class="font-display text-xl font-bold mb-3 pb-2 border-b border-gris-chaud">Coh&eacute;rence discours / votes</h2>
            <div class="flex items-center gap-4 mb-3">
              <div class="font-mono text-4xl font-bold" style={`color: ${getCoherenceColor(personne.score_coherence)}`}>
                {personne.score_coherence}%
              </div>
              <div class="text-sm text-gris-texte">
                Ce score mesure la correspondance entre les prises de position publiques et les votes effectifs en s&eacute;ance.
              </div>
            </div>
            <div class="h-2 bg-gris-chaud rounded-full overflow-hidden">
              <div
                class="h-full rounded-full transition-all duration-1000"
                style={`width: ${personne.score_coherence}%; background: ${getCoherenceColor(personne.score_coherence)}`}
              ></div>
            </div>
            <p class="text-xs text-gris-clair mt-2 italic">
              M&eacute;thodologie : analyse crois&eacute;e des d&eacute;clarations publiques (m&eacute;dias, r&eacute;seaux sociaux, h&eacute;micycle) et des votes nominatifs. Score calcul&eacute; sur les 12 derniers mois.
            </p>
          </section>
        )}

        <!-- Apparitions média -->
        {personne.apparitions_media.length > 0 && (
          <section class="bg-blanc border border-gris-chaud rounded-lg p-6 mb-4">
            <h2 class="font-display text-xl font-bold mb-4 pb-2 border-b border-gris-chaud">Apparitions m&eacute;dia</h2>
            <div class="space-y-0">
              {personne.apparitions_media.map((app: { date: string; media: string; titre?: string; url?: string }) => (
                <div class="flex items-center gap-3 py-3 border-b border-gris-chaud last:border-0">
                  <span class="shrink-0 text-xs font-semibold text-orange bg-orange-50 px-2 py-0.5 rounded">
                    {app.media}
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium truncate">{app.titre || 'Apparition'}</div>
                    <div class="text-xs text-gris-clair">{formatDateShort(app.date)}</div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
