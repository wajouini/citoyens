---
import { getCollection } from 'astro:content';
import { dedupBriefings, dedupArticles, getTopicsForSection } from '../../utils/section-data';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import FilSidebar from '../../components/section/FilSidebar.astro';

const allArticles = await getCollection('articles');
const rawArticles = allArticles
  .filter(a => a.data.rubrique === 'tech')
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
const articles = dedupArticles(rawArticles);

const hero = articles.find(a => a.data.estUne) ?? articles[0];
const rest = articles.filter(a => a.id !== hero?.id);

const iaData = await import('../../data/ia.json').then(m => m.default).catch(() => null);
const allFaitsIA: any[] = iaData?.faits_ia ?? [];

// Dédupliquer les faits IA déjà couverts par des articles MDX
const coveredTitles = articles.map(a => a.data.titre);
const faitsIA = dedupBriefings(allFaitsIA, coveredTitles);

// ── Fil sidebar — topics importants tech/science ─────────────────────────────
const topicsData = await import('../../data/.pipeline/topics-tagged.json').then(m => m.default).catch(() =>
  import('../../data/.pipeline/topics.json').then(m => m.default).catch(() => null)
);
const pipelineArticles = await import('../../data/.pipeline/raw-articles.json').then(m => m.default).catch(() => []);
const filItems = topicsData
  ? getTopicsForSection(topicsData, pipelineArticles, ['ia', 'spatial', 'medecine', 'robotique', 'automobile', 'transport', 'energie', 'electronique', 'cybersec', 'architecture', 'science'], 7)
  : [];

const sousSection: Record<string, { label: string; color: string; bg: string }> = {
  annonces:  { label: 'Annonces',   color: 'text-indigo-700', bg: 'bg-indigo-50' },
  regulation:{ label: 'Régulation', color: 'text-rouge-doux', bg: 'bg-red-50' },
  recherche: { label: 'Recherche',  color: 'text-vert',       bg: 'bg-green-50' },
  business:  { label: 'Business',   color: 'text-orange',     bg: 'bg-orange/10' },
  societe:   { label: 'Société',    color: 'text-purple-700', bg: 'bg-purple-50' },
};

const formatDate = (d: string) =>
  new Date(d + 'T00:00:00').toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'long', year: 'numeric',
  });

const formatDateShort = (d: string) =>
  new Date(d + 'T00:00:00').toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'short',
  });
---

<BaseLayout
  title="Tech & IA — Citoyens.ai"
  description="Décryptage de l'actualité technologique et de l'intelligence artificielle. Contexte, faits, enjeux — avec toutes les sources."
>
  <Header />

  <main class="max-w-[1280px] mx-auto px-4 md:px-6 py-8 md:py-12">

    {/* Section header */}
    <div class="flex items-center gap-4 mb-10 pb-4 border-b-2 border-purple-600">
      <h1 class="font-display text-[32px] md:text-[40px] font-black text-noir tracking-tight">Tech & IA</h1>
      <span class="font-mono text-[11px] uppercase tracking-[2px] text-purple-700 bg-purple-50 px-2.5 py-1 rounded">
        Analyse & décryptage
      </span>
    </div>

    <div class="flex flex-col lg:flex-row gap-10 lg:gap-14">

      {/* Main column */}
      <div class="flex-1 min-w-0">

        {/* Hero article */}
        {hero && (
          <a href={`/article/${hero.id}`} class="block group no-underline mb-12">
            <div class="border-l-4 border-purple-600 pl-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-purple-700 bg-purple-50 px-2 py-0.5 rounded">
                  À la une
                </span>
                <time class="font-mono text-[11px] text-gris-clair">{formatDate(hero.data.date)}</time>
              </div>
              <h2 class="font-display text-[26px] md:text-[34px] font-black text-noir leading-[1.1] tracking-tight mb-3 group-hover:text-purple-700 transition-colors">
                {hero.data.titre}
              </h2>
              <p class="text-[16px] text-gris-texte leading-relaxed mb-4 max-w-[640px]">
                {hero.data.resume}
              </p>
              <span class="inline-flex items-center gap-1 font-mono text-[12px] text-purple-700 font-semibold group-hover:underline">
                Lire l'article →
              </span>
            </div>
          </a>
        )}

        {/* Other articles */}
        {rest.length > 0 && (
          <div class="mb-12">
            <div class="flex items-center gap-2 mb-6">
              <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-gris-clair">Autres analyses</span>
              <div class="flex-1 h-px bg-gris-chaud"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {rest.map(a => (
                <a href={`/article/${a.id}`} class="block group no-underline p-5 rounded-xl border border-gris-chaud bg-blanc hover:border-purple-300 hover:shadow-md transition-all">
                  <time class="font-mono text-[10px] text-gris-clair block mb-2">{formatDateShort(a.data.date)}</time>
                  <h3 class="font-display text-[18px] font-bold text-noir leading-snug mb-2 group-hover:text-purple-700 transition-colors">
                    {a.data.titre}
                  </h3>
                  <p class="text-[13px] text-gris-texte leading-relaxed line-clamp-3">{a.data.resume}</p>
                  <span class="inline-block mt-3 font-mono text-[11px] text-purple-700 font-semibold group-hover:underline">
                    Lire →
                  </span>
                </a>
              ))}
            </div>
          </div>
        )}

        {/* IA Briefing section */}
        {faitsIA.length > 0 && (
          <div>
            <div class="flex items-center gap-3 mb-6">
              <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-indigo-700 bg-indigo-50 px-2.5 py-1 rounded">
                Briefing IA du jour
              </span>
              <div class="flex-1 h-px bg-indigo-100"></div>
            </div>
            <div class="flex flex-col gap-4">
              {faitsIA.map((fait: any) => {
                const ss = sousSection[fait.sous_section] ?? sousSection.annonces;
                return (
                  <div class="p-4 rounded-xl border border-gris-chaud bg-blanc hover:border-indigo-200 transition-colors">
                    <div class="flex items-center gap-2 mb-2">
                      <span class={`font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${ss.bg} ${ss.color}`}>
                        {ss.label}
                      </span>
                    </div>
                    <h3 class="font-display text-[16px] font-bold text-noir leading-snug mb-1">
                      {fait.titre}
                    </h3>
                    <p class="text-[13px] text-gris-texte leading-relaxed mb-2">{fait.resume}</p>
                    {fait.pourquoi_ca_compte && (
                      <p class="text-[12px] text-bleu-rep font-semibold leading-snug border-l-2 border-bleu-rep/30 pl-2 mb-2">
                        {fait.pourquoi_ca_compte}
                      </p>
                    )}
                    {fait.lien && (
                      <a
                        href={fait.lien}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-mono text-[11px] text-indigo-700 no-underline hover:underline"
                      >
                        Source principale ↗
                      </a>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {articles.length === 0 && faitsIA.length === 0 && (
          <div class="py-20 text-center text-gris-clair font-mono text-[13px]">
            Aucun article tech disponible pour l'instant.
          </div>
        )}

      </div>

      {/* Sidebar */}
      <aside class="w-full lg:w-[300px] shrink-0 lg:sticky lg:top-24 self-start">
        <FilSidebar
          items={filItems}
          label="Sujets du moment"
          accentColor="text-purple-700"
          dotColor="bg-purple-600"
          headerBg="bg-purple-50"
        />
      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>
