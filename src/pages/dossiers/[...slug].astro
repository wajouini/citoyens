---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import TLDR from '../../components/ui/TLDR.astro';
import { formatDateShort } from '../../utils/format';
import { getPartiColor } from '../../utils/colors';
import { getArticlesLies } from '../../utils/dossier-articles';

export async function getStaticPaths() {
  const dossiers = await getCollection('dossiers');
  return dossiers.map(d => ({
    params: { slug: d.id },
    props: { dossier: d },
  }));
}

const { dossier } = Astro.props;

const articlesLies = await getArticlesLies(dossier.data.mots_cles || [], 6);

const statutLabels: Record<string, string> = {
  en_cours: 'En cours',
  adopte: 'Adopté',
  rejete: 'Rejeté',
  en_commission: 'En commission',
  promulgue: 'Promulgué',
};

const statutColors: Record<string, string> = {
  en_cours: 'bg-blue-50 text-bleu-rep',
  adopte: 'bg-green-50 text-vert',
  rejete: 'bg-red-50 text-rouge-doux',
  en_commission: 'bg-orange-50 text-orange',
  promulgue: 'bg-green-50 text-vert',
};

const positionColors: Record<string, { bg: string; text: string; label: string }> = {
  pour: { bg: 'bg-green-50', text: 'text-vert', label: 'Pour' },
  contre: { bg: 'bg-red-50', text: 'text-rouge-doux', label: 'Contre' },
  mitige: { bg: 'bg-orange-50', text: 'text-orange', label: 'Mitigé' },
  abstention: { bg: 'bg-gray-100', text: 'text-gris-clair', label: 'Abstention' },
};

const sourceIcons: Record<string, string> = {
  officiel: '🏛',
  presse: '📰',
  analyse: '🔍',
};

const positions = dossier.data.positions || [];
const sources = dossier.data.sources || [];
const acteurs = dossier.data.acteurs_cles || [];
const chronologie = dossier.data.chronologie || [];
const argumentsPour = dossier.data.arguments_pour || [];
const argumentsContre = dossier.data.arguments_contre || [];
const contexte = dossier.data.contexte || '';
const enjeux = dossier.data.enjeux || [];
const chiffres = dossier.data.chiffres || [];

const chronoStyles: Record<string, { dot: string; line: string; text: string; bg: string }> = {
  passe: { dot: 'bg-bleu-rep', line: 'bg-bleu-rep', text: 'text-noir', bg: '' },
  en_cours: { dot: 'bg-bleu-rep ring-4 ring-blue-100', line: 'bg-gris-chaud', text: 'text-bleu-rep font-semibold', bg: 'bg-blue-50' },
  prevu: { dot: 'bg-gris-chaud', line: 'bg-gris-chaud', text: 'text-gris-clair', bg: '' },
};

// Find current step for summary display
const currentStep = chronologie.find((c: { statut: string }) => c.statut === 'en_cours');
const passedCount = chronologie.filter((c: { statut: string }) => c.statut === 'passe').length;
---

<BaseLayout title={dossier.data.titre} description={dossier.data.description}>
  <Header />

  <main class="max-w-[1280px] mx-auto px-6 py-8">
    <!-- Breadcrumbs -->
    <nav class="text-xs text-gris-clair mb-6">
      <a href="/" class="hover:text-noir no-underline text-gris-clair">Accueil</a>
      <span class="mx-1.5">&rsaquo;</span>
      <a href="/dossiers" class="hover:text-noir no-underline text-gris-clair">Dossiers</a>
      <span class="mx-1.5">&rsaquo;</span>
      <span class="text-noir">{dossier.data.titre}</span>
    </nav>

    <!-- Hero Header -->
    <div class="bg-blanc border border-gris-chaud rounded-xl overflow-hidden mb-6">
      <div class="h-2 bg-bleu-rep"></div>
      <div class="p-6 sm:p-8">
        <div class="flex items-start gap-4 mb-4">
          <div class="w-16 h-16 bg-bleu-clair rounded-xl flex items-center justify-center text-[32px] shrink-0">
            {dossier.data.icone}
          </div>
          <div class="flex-1">
            <h1 class="font-display text-3xl sm:text-4xl font-black leading-tight mb-2">{dossier.data.titre}</h1>
            <p class="text-[15px] text-gris-texte leading-relaxed">{dossier.data.description}</p>
          </div>
        </div>

        <!-- Status bar -->
        <div class="flex flex-wrap items-center gap-3 mt-4">
          <span class={`text-[11px] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full ${statutColors[dossier.data.statut] || 'bg-gray-50 text-gris-clair'}`}>
            {statutLabels[dossier.data.statut] || dossier.data.statut}
          </span>
          <div class="flex items-center gap-2 flex-1 max-w-[300px]">
            <div class="flex-1 h-[5px] bg-gris-chaud rounded-full overflow-hidden">
              <div class="h-full bg-bleu-rep rounded-full transition-all" style={`width:${dossier.data.progression}%`}></div>
            </div>
            <span class="font-mono text-[11px] text-gris-clair whitespace-nowrap">{dossier.data.progression}%</span>
          </div>
          <span class="font-mono text-[11px] text-gris-clair">{dossier.data.etape_label}</span>
          {dossier.data.date_maj && (
            <span class="text-[10px] text-gris-clair ml-auto">Mis à jour le {formatDateShort(dossier.data.date_maj)}</span>
          )}
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-10 lg:gap-16">
      <!-- Main Content -->
      <div class="space-y-10">
        <!-- TLDR -->
        {dossier.data.tldr && dossier.data.tldr.length > 0 && (
          <TLDR points={dossier.data.tldr} readingTime="45 sec" />
        )}

        <!-- Contexte -->
        {contexte && (
          <div class="bg-blanc border border-gris-chaud rounded-xl p-6 sm:p-8">
            <h2 class="font-display text-lg font-bold text-noir mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-bleu-clair rounded-lg flex items-center justify-center text-sm">📋</span>
              De quoi parle ce texte ?
            </h2>
            <div class="space-y-3">
              {contexte.split('\n\n').map((paragraph: string) => (
                <p class="text-[15px] leading-relaxed text-gris-texte" set:html={paragraph.replace(/\*\*(.*?)\*\*/g, '<strong class="text-noir font-semibold">$1</strong>')} />
              ))}
            </div>
          </div>
        )}

        <!-- Enjeux clés -->
        {enjeux.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-xl p-6 sm:p-8">
            <h2 class="font-display text-lg font-bold text-noir mb-5 flex items-center gap-2">
              <span class="w-8 h-8 bg-orange/10 rounded-lg flex items-center justify-center text-sm">⚡</span>
              Les enjeux clés
            </h2>
            <div class="space-y-4">
              {enjeux.map((e: { titre: string; description: string }, i: number) => (
                <div class="bg-creme/50 border border-gris-chaud/50 rounded-lg p-4 sm:p-5">
                  <div class="flex items-start gap-3">
                    <span class="font-mono text-xs font-bold text-bleu-rep bg-bleu-clair w-6 h-6 rounded-md flex items-center justify-center shrink-0 mt-0.5">
                      {i + 1}
                    </span>
                    <div class="flex-1 min-w-0">
                      <h3 class="font-display font-bold text-[15px] text-noir mb-2">{e.titre}</h3>
                      <p class="text-[13px] leading-relaxed text-gris-texte" set:html={e.description.replace(/\*\*(.*?)\*\*/g, '<strong class="text-noir font-semibold">$1</strong>')} />
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Chiffres clés -->
        {chiffres.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-xl p-6 sm:p-8">
            <h2 class="font-display text-lg font-bold text-noir mb-5 flex items-center gap-2">
              <span class="w-8 h-8 bg-vert/10 rounded-lg flex items-center justify-center text-sm">📊</span>
              Ce que disent les chiffres
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {chiffres.map((c: { indicateur: string; valeur: string; source: string; source_url?: string }) => (
                <div class="bg-creme/50 border border-gris-chaud/50 rounded-lg p-3.5 text-center">
                  <div class="font-display font-black text-lg text-bleu-rep leading-tight mb-1">{c.valeur}</div>
                  <div class="text-[11px] text-noir font-medium leading-snug mb-1.5">{c.indicateur}</div>
                  {c.source_url ? (
                    <a href={c.source_url} target="_blank" rel="noopener noreferrer" class="text-[9px] text-gris-clair uppercase tracking-wider no-underline hover:text-bleu-rep hover:underline transition-colors">
                      {c.source} ↗
                    </a>
                  ) : (
                    <div class="text-[9px] text-gris-clair uppercase tracking-wider">{c.source}</div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Arguments Pour / Contre -->
        {(argumentsPour.length > 0 || argumentsContre.length > 0) && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {/* Pour */}
            {argumentsPour.length > 0 && (
              <div class="bg-blanc border border-gris-chaud rounded-xl overflow-hidden">
                <div class="bg-vert/10 border-b border-vert/20 px-5 py-3 flex items-center gap-2">
                  <span class="w-6 h-6 bg-vert rounded-full flex items-center justify-center text-blanc text-xs font-bold">✓</span>
                  <h3 class="text-sm font-bold text-vert">Arguments pour</h3>
                  <span class="ml-auto font-mono text-[11px] text-vert/70">{argumentsPour.length}</span>
                </div>
                <ul class="p-5 space-y-3">
                  {argumentsPour.map((arg: string) => (
                    <li class="flex gap-2.5 text-[13px] leading-relaxed text-gris-texte">
                      <span class="text-vert shrink-0 mt-0.5 text-xs">▸</span>
                      <span>{arg}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {/* Contre */}
            {argumentsContre.length > 0 && (
              <div class="bg-blanc border border-gris-chaud rounded-xl overflow-hidden">
                <div class="bg-rouge-doux/10 border-b border-rouge-doux/20 px-5 py-3 flex items-center gap-2">
                  <span class="w-6 h-6 bg-rouge-doux rounded-full flex items-center justify-center text-blanc text-xs font-bold">✗</span>
                  <h3 class="text-sm font-bold text-rouge-doux">Arguments contre</h3>
                  <span class="ml-auto font-mono text-[11px] text-rouge-doux/70">{argumentsContre.length}</span>
                </div>
                <ul class="p-5 space-y-3">
                  {argumentsContre.map((arg: string) => (
                    <li class="flex gap-2.5 text-[13px] leading-relaxed text-gris-texte">
                      <span class="text-rouge-doux shrink-0 mt-0.5 text-xs">▸</span>
                      <span>{arg}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )}

        <!-- Section Agir -->
        <div class="bg-blanc border border-gris-chaud rounded-xl p-6 sm:p-8">
          <h2 class="font-display text-lg font-bold text-noir mb-4 flex items-center gap-2">
            <span class="w-8 h-8 bg-rouge-rep/10 rounded-lg flex items-center justify-center text-sm">✊</span>
            Agir
          </h2>
          <p class="text-[13px] text-gris-texte leading-relaxed mb-5">
            Ce dossier vous concerne ? Faites entendre votre voix auprès de vos représentants ou partagez ces informations.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-5">
            <!-- Écrire à mon député -->
            <a
              href={`/fiche`}
              class="flex items-center gap-3 p-4 rounded-lg border border-bleu-rep/20 bg-bleu-clair no-underline hover:border-bleu-rep hover:shadow-sm transition-all group"
            >
              <span class="w-10 h-10 bg-bleu-rep rounded-lg flex items-center justify-center text-blanc text-lg shrink-0">✉</span>
              <div>
                <div class="font-display font-bold text-[14px] text-bleu-rep group-hover:underline">Écrire à mon député</div>
                <div class="text-[11px] text-gris-texte">Trouvez votre élu et contactez-le</div>
              </div>
            </a>

            <!-- Consulter la source officielle -->
            {sources.length > 0 && sources.find((s: { type: string }) => s.type === 'officiel') && (
              <a
                href={sources.find((s: { type: string }) => s.type === 'officiel')!.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-4 rounded-lg border border-gris-chaud bg-blanc no-underline hover:border-bleu-rep hover:shadow-sm transition-all group"
              >
                <span class="w-10 h-10 bg-creme rounded-lg flex items-center justify-center text-lg shrink-0">🏛</span>
                <div>
                  <div class="font-display font-bold text-[14px] text-noir group-hover:text-bleu-rep">Lire le texte officiel</div>
                  <div class="text-[11px] text-gris-texte">assemblee-nationale.fr</div>
                </div>
              </a>
            )}
          </div>

          <!-- Boutons de partage -->
          <div class="flex items-center gap-2 pt-4 border-t border-gris-chaud">
            <span class="text-[11px] text-gris-clair uppercase tracking-wider mr-2">Partager</span>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(dossier.data.titre + ' — Les faits, les chiffres, les arguments.')}&url=${encodeURIComponent('https://citoyens.ai/dossiers/' + dossier.id)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-8 h-8 rounded-full bg-noir text-blanc text-xs no-underline hover:bg-bleu-rep transition-colors"
              title="Partager sur X"
            >
              𝕏
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://citoyens.ai/dossiers/' + dossier.id)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-8 h-8 rounded-full bg-[#1877F2] text-blanc text-xs font-bold no-underline hover:opacity-80 transition-opacity"
              title="Partager sur Facebook"
            >
              f
            </a>
            <button
              onclick={`navigator.clipboard.writeText('https://citoyens.ai/dossiers/${dossier.id}');this.textContent='✓';setTimeout(()=>this.textContent='🔗',1500)`}
              class="flex items-center justify-center w-8 h-8 rounded-full bg-gris-chaud text-noir text-xs cursor-pointer hover:bg-gris-clair/30 transition-colors border-0"
              title="Copier le lien"
            >
              🔗
            </button>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-8">
        <!-- Chronologie (collapsible) -->
        {chronologie.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-lg overflow-hidden">
            <details class="group">
              <summary class="p-5 cursor-pointer select-none list-none flex items-center gap-3 hover:bg-creme/50 transition-colors">
                <span class="text-[11px] uppercase tracking-[1.5px] text-gris-clair flex items-center gap-1.5 flex-1">
                  📅 Chronologie
                </span>
                {currentStep && (
                  <span class="text-[10px] font-semibold text-bleu-rep bg-blue-50 px-2 py-0.5 rounded-full flex items-center gap-1">
                    <span class="w-1.5 h-1.5 bg-bleu-rep rounded-full animate-pulse" />
                    {currentStep.date}
                  </span>
                )}
                <span class="font-mono text-[10px] text-gris-clair">{passedCount}/{chronologie.length}</span>
                <svg class="w-4 h-4 text-gris-clair transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 border-t border-gris-chaud/50">
                <div class="relative pt-4">
                  {chronologie.map((c: { date: string; evenement: string; statut: string }, i: number) => {
                    const style = chronoStyles[c.statut] || chronoStyles.prevu;
                    const isLast = i === chronologie.length - 1;
                    return (
                      <div class="flex gap-3 relative">
                        {/* Vertical line */}
                        {!isLast && (
                          <div class={`absolute left-[8px] top-[20px] bottom-0 w-[2px] ${style.line}`} />
                        )}
                        {/* Dot */}
                        <div class="relative shrink-0 mt-1">
                          <div class={`w-[16px] h-[16px] rounded-full border-2 border-blanc ${style.dot}`} />
                        </div>
                        {/* Content */}
                        <div class={`flex-1 pb-4 ${isLast ? 'pb-0' : ''}`}>
                          <div class={`rounded-md px-2.5 py-1.5 ${style.bg}`}>
                            <span class="font-mono text-[10px] text-gris-clair block">{c.date}</span>
                            <span class={`text-[12px] leading-snug ${style.text}`}>{c.evenement}</span>
                            {c.statut === 'en_cours' && (
                              <span class="inline-flex items-center gap-1 ml-1.5 text-[9px] font-semibold text-bleu-rep bg-blue-100 px-1.5 py-0.5 rounded-full align-middle">
                                <span class="w-1 h-1 bg-bleu-rep rounded-full animate-pulse" />
                                En cours
                              </span>
                            )}
                            {c.statut === 'prevu' && (
                              <span class="inline-flex ml-1.5 text-[9px] text-gris-clair bg-gray-100 px-1.5 py-0.5 rounded-full align-middle">
                                À venir
                              </span>
                            )}
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            </details>
          </div>
        )}

        <!-- Positions des groupes -->
        {positions.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-lg p-5">
            <h3 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-4 flex items-center gap-1.5">
              🏛 Positions des groupes
            </h3>
            <div class="space-y-3">
              {positions.map((p: { groupe: string; position: string; resume: string }) => {
                const pc = positionColors[p.position] || positionColors.mitige;
                const groupColor = getPartiColor(p.groupe);
                return (
                  <div class="border-b border-gris-chaud/50 pb-3 last:border-0 last:pb-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="w-2.5 h-2.5 rounded-full shrink-0" style={`background: ${groupColor}`}></span>
                      <span class="font-semibold text-sm">{p.groupe}</span>
                      <span class={`text-[10px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded ${pc.bg} ${pc.text} ml-auto`}>
                        {pc.label}
                      </span>
                    </div>
                    <p class="text-[12px] text-gris-texte leading-relaxed ml-[18px]">{p.resume}</p>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- Acteurs clés -->
        {acteurs.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-lg p-5">
            <h3 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-3 flex items-center gap-1.5">
              👥 Acteurs clés
            </h3>
            <div class="space-y-2.5">
              {acteurs.map((a: { nom: string; role: string; slug?: string }) => (
                <div class="flex items-start gap-2 text-sm">
                  <span class="text-bleu-rep mt-0.5">•</span>
                  <div>
                    {a.slug ? (
                      <a href={`/fiche/${a.slug}`} class="font-semibold text-bleu-rep no-underline hover:underline">{a.nom}</a>
                    ) : (
                      <span class="font-semibold">{a.nom}</span>
                    )}
                    <div class="text-[11px] text-gris-clair">{a.role}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Sources -->
        {sources.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-lg p-5">
            <h3 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-3 flex items-center gap-1.5">
              📎 Sources et références
            </h3>
            <div class="space-y-2">
              {sources.map((s: { titre: string; url: string; type: string }) => (
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-start gap-2 text-sm no-underline hover:bg-creme rounded-md px-2 py-1.5 -mx-2 transition-colors group"
                >
                  <span class="shrink-0 mt-0.5">{sourceIcons[s.type] || '📄'}</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-bleu-rep font-medium group-hover:underline leading-snug">{s.titre}</div>
                    <div class="text-[10px] text-gris-clair capitalize">{s.type}</div>
                  </div>
                  <span class="text-gris-clair text-xs shrink-0">↗</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Dans l'actualité récente -->
        {articlesLies.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-lg overflow-hidden">
            <div class="px-5 py-3.5 border-b border-gris-chaud flex items-center gap-2">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rouge-doux opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-rouge-doux"></span>
              </span>
              <h3 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair">Dans l'actualité récente</h3>
            </div>
            <div class="divide-y divide-gris-chaud/50">
              {articlesLies.map((article) => (
                <a
                  href={article.href}
                  class="block px-5 py-3.5 no-underline hover:bg-creme transition-colors group"
                >
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-mono text-[9px] text-gris-clair uppercase tracking-wider">
                      {new Date(article.date + 'T00:00:00').toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })}
                    </span>
                    <span class={`font-mono text-[9px] px-1.5 py-0.5 rounded ${article.edition === 'soir' ? 'bg-indigo-50 text-indigo-600' : 'bg-bleu-clair text-bleu-rep'}`}>
                      {article.edition === 'soir' ? 'Ce soir' : 'La Une'}
                    </span>
                  </div>
                  <p class="text-[13px] text-noir font-medium leading-snug group-hover:text-bleu-rep transition-colors">{article.titre}</p>
                  {article.resume && (
                    <p class="text-[11px] text-gris-clair mt-0.5 leading-relaxed line-clamp-2">{article.resume}</p>
                  )}
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Note -->
        <div class="bg-creme rounded-lg p-4 text-xs text-gris-clair leading-relaxed">
          <p class="font-semibold text-gris-texte mb-1">⚠ Note de transparence</p>
          <p>
