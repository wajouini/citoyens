---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { formatDateShort } from '../../utils/format';
import { getPartiColor } from '../../utils/colors';

export async function getStaticPaths() {
  const dossiers = await getCollection('dossiers');
  return dossiers.map(d => ({
    params: { slug: d.id },
    props: { dossier: d },
  }));
}

const { dossier } = Astro.props;
const { Content } = await render(dossier);

const statutLabels: Record<string, string> = {
  en_cours: 'En cours',
  adopte: 'Adopté',
  rejete: 'Rejeté',
  en_commission: 'En commission',
  promulgue: 'Promulgué',
};

const statutColors: Record<string, string> = {
  en_cours: 'bg-blue-50 text-bleu-rep',
  adopte: 'bg-green-50 text-vert',
  rejete: 'bg-red-50 text-rouge-doux',
  en_commission: 'bg-orange-50 text-orange',
  promulgue: 'bg-green-50 text-vert',
};

const positionColors: Record<string, { bg: string; text: string; label: string }> = {
  pour: { bg: 'bg-green-50', text: 'text-vert', label: 'Pour' },
  contre: { bg: 'bg-red-50', text: 'text-rouge-doux', label: 'Contre' },
  mitige: { bg: 'bg-orange-50', text: 'text-orange', label: 'Mitigé' },
  abstention: { bg: 'bg-gray-100', text: 'text-gris-clair', label: 'Abstention' },
};

const sourceIcons: Record<string, string> = {
  officiel: '🏛',
  presse: '📰',
  analyse: '🔍',
};

const positions = dossier.data.positions || [];
const sources = dossier.data.sources || [];
const acteurs = dossier.data.acteurs_cles || [];
---

<BaseLayout title={dossier.data.titre} description={dossier.data.description}>
  <Header />

  <main class="max-w-[1280px] mx-auto px-6 py-8">
    <!-- Breadcrumbs -->
    <nav class="text-xs text-gris-clair mb-6">
      <a href="/" class="hover:text-noir no-underline text-gris-clair">Accueil</a>
      <span class="mx-1.5">&rsaquo;</span>
      <a href="/dossiers" class="hover:text-noir no-underline text-gris-clair">Dossiers</a>
      <span class="mx-1.5">&rsaquo;</span>
      <span class="text-noir">{dossier.data.titre}</span>
    </nav>

    <!-- Hero Header -->
    <div class="bg-blanc border border-gris-chaud rounded-xl overflow-hidden mb-6">
      <div class="h-2 bg-bleu-rep"></div>
      <div class="p-6 sm:p-8">
        <div class="flex items-start gap-4 mb-4">
          <div class="w-16 h-16 bg-bleu-clair rounded-xl flex items-center justify-center text-[32px] shrink-0">
            {dossier.data.icone}
          </div>
          <div class="flex-1">
            <h1 class="font-display text-3xl sm:text-4xl font-black leading-tight mb-2">{dossier.data.titre}</h1>
            <p class="text-[15px] text-gris-texte leading-relaxed">{dossier.data.description}</p>
          </div>
        </div>

        <!-- Status bar -->
        <div class="flex flex-wrap items-center gap-3 mt-4">
          <span class={`text-[11px] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full ${statutColors[dossier.data.statut] || 'bg-gray-50 text-gris-clair'}`}>
            {statutLabels[dossier.data.statut] || dossier.data.statut}
          </span>
          <div class="flex items-center gap-2 flex-1 max-w-[300px]">
            <div class="flex-1 h-[5px] bg-gris-chaud rounded-full overflow-hidden">
              <div class="h-full bg-bleu-rep rounded-full transition-all" style={`width:${dossier.data.progression}%`}></div>
            </div>
            <span class="font-mono text-[11px] text-gris-clair whitespace-nowrap">{dossier.data.progression}%</span>
          </div>
          <span class="font-mono text-[11px] text-gris-clair">{dossier.data.etape_label}</span>
          {dossier.data.date_maj && (
            <span class="text-[10px] text-gris-clair ml-auto">Mis à jour le {formatDateShort(dossier.data.date_maj)}</span>
          )}
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-6">
      <!-- Main Content -->
      <div>
        <!-- Article body -->
        <article class="bg-blanc border border-gris-chaud rounded-lg p-6 sm:p-8 prose prose-neutral max-w-none
          prose-headings:font-display prose-headings:font-bold
          prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b prose-h2:border-gris-chaud
          prose-h3:text-base prose-h3:mt-6 prose-h3:mb-2
          prose-p:text-[15px] prose-p:leading-relaxed prose-p:text-gris-texte
          prose-li:text-[15px] prose-li:text-gris-texte
          prose-strong:text-noir
          prose-a:text-bleu-rep prose-a:no-underline hover:prose-a:underline
          prose-hr:border-gris-chaud prose-hr:my-6
          prose-table:text-[13px] prose-th:text-left prose-th:font-semibold prose-th:text-noir prose-th:pb-2 prose-th:border-b-2 prose-th:border-gris-chaud
          prose-td:py-2 prose-td:border-b prose-td:border-gris-chaud prose-td:text-gris-texte">
          <Content />
        </article>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Positions des groupes -->
        {positions.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-lg p-5">
            <h3 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-4 flex items-center gap-1.5">
              🏛 Positions des groupes
            </h3>
            <div class="space-y-3">
              {positions.map((p: { groupe: string; position: string; resume: string }) => {
                const pc = positionColors[p.position] || positionColors.mitige;
                const groupColor = getPartiColor(p.groupe);
                return (
                  <div class="border-b border-gris-chaud/50 pb-3 last:border-0 last:pb-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="w-2.5 h-2.5 rounded-full shrink-0" style={`background: ${groupColor}`}></span>
                      <span class="font-semibold text-sm">{p.groupe}</span>
                      <span class={`text-[10px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded ${pc.bg} ${pc.text} ml-auto`}>
                        {pc.label}
                      </span>
                    </div>
                    <p class="text-[12px] text-gris-texte leading-relaxed ml-[18px]">{p.resume}</p>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- Acteurs clés -->
        {acteurs.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-lg p-5">
            <h3 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-3 flex items-center gap-1.5">
              👥 Acteurs clés
            </h3>
            <div class="space-y-2.5">
              {acteurs.map((a: { nom: string; role: string; slug?: string }) => (
                <div class="flex items-start gap-2 text-sm">
                  <span class="text-bleu-rep mt-0.5">•</span>
                  <div>
                    {a.slug ? (
                      <a href={`/fiche/${a.slug}`} class="font-semibold text-bleu-rep no-underline hover:underline">{a.nom}</a>
                    ) : (
                      <span class="font-semibold">{a.nom}</span>
                    )}
                    <div class="text-[11px] text-gris-clair">{a.role}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Sources -->
        {sources.length > 0 && (
          <div class="bg-blanc border border-gris-chaud rounded-lg p-5">
            <h3 class="text-[11px] uppercase tracking-[1.5px] text-gris-clair mb-3 flex items-center gap-1.5">
              📎 Sources et références
            </h3>
            <div class="space-y-2">
              {sources.map((s: { titre: string; url: string; type: string }) => (
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-start gap-2 text-sm no-underline hover:bg-creme rounded-md px-2 py-1.5 -mx-2 transition-colors group"
                >
                  <span class="shrink-0 mt-0.5">{sourceIcons[s.type] || '📄'}</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-bleu-rep font-medium group-hover:underline leading-snug">{s.titre}</div>
                    <div class="text-[10px] text-gris-clair capitalize">{s.type}</div>
                  </div>
                  <span class="text-gris-clair text-xs shrink-0">↗</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Note -->
        <div class="bg-creme rounded-lg p-4 text-xs text-gris-clair leading-relaxed">
          <p class="font-semibold text-gris-texte mb-1">⚠ Note de transparence</p>
          <p>
            Ce dossier est un résumé pédagogique à visée citoyenne. Les positions des groupes sont simplifiées et peuvent ne pas refléter les nuances de chaque député. Consultez les sources officielles pour une vision complète.
          </p>
        </div>
      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>
