---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(a => ({
    params: { slug: a.id },
    props: { article: a },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const rubriqueLabels: Record<string, string> = {
  politique: 'Politique',
  economie: 'Économie',
  tech: 'Tech & IA',
};

const rubriqueStyles: Record<string, { color: string; bg: string; href: string; border: string }> = {
  politique: { color: 'text-bleu-rep',   bg: 'bg-bleu-clair', href: '/politique', border: 'border-bleu-rep' },
  economie:  { color: 'text-orange',     bg: 'bg-orange/10',  href: '/economie',  border: 'border-orange' },
  tech:      { color: 'text-purple-700', bg: 'bg-purple-50',  href: '/tech',      border: 'border-purple-600' },
};

const style = rubriqueStyles[article.data.rubrique] ?? rubriqueStyles.politique;
const label = rubriqueLabels[article.data.rubrique] ?? article.data.rubrique;

const formatDate = (d: string) =>
  new Date(d + 'T00:00:00').toLocaleDateString('fr-FR', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  });

const readingTime = Math.max(2, Math.ceil((article.body?.length ?? 0) / 1200));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: article.data.titre,
  description: article.data.resume,
  datePublished: article.data.date,
  publisher: { '@type': 'Organization', name: 'Citoyens.ai', url: 'https://citoyens.ai' },
  author: { '@type': 'Organization', name: 'Rédaction Citoyens.ai' },
};
---

<BaseLayout
  title={article.data.titre}
  description={article.data.resume}
  jsonLd={jsonLd}
>
  <Header />

  <main class="max-w-[1280px] mx-auto px-4 md:px-6 py-8 md:py-12">
    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16">

      {/* ── Article principal ── */}
      <div class="flex-1 min-w-0 max-w-[720px]">

        {/* Breadcrumb */}
        <nav aria-label="Fil d'Ariane" class="flex items-center gap-1.5 mb-6 text-[12px] font-mono text-gris-clair">
          <a href="/" class="hover:text-bleu-rep transition-colors no-underline">Citoyens.ai</a>
          <span aria-hidden="true">›</span>
          <a href={style.href} class={`hover:underline no-underline font-semibold ${style.color}`}>{label}</a>
          <span aria-hidden="true">›</span>
          <span class="text-gris-texte truncate max-w-[260px]">{article.data.titre}</span>
        </nav>

        {/* ── Header ── */}
        <header class="mb-8">
          <div class="flex items-center gap-2 mb-4">
            <a
              href={style.href}
              class={`font-mono text-[10px] font-bold uppercase tracking-[2px] px-2.5 py-1 rounded no-underline ${style.bg} ${style.color}`}
            >
              {label}
            </a>
            <time class="font-mono text-[11px] text-gris-clair" datetime={article.data.date}>
              {formatDate(article.data.date)}
            </time>
            <span class="font-mono text-[11px] text-gris-clair">· {readingTime} min</span>
          </div>

          <h1 class="font-display text-[26px] md:text-[38px] font-black leading-[1.08] tracking-tight text-noir mb-5">
            {article.data.titre}
          </h1>

          {/* Lead */}
          <p class={`text-[17px] md:text-[18px] font-semibold leading-snug border-l-4 ${style.border} pl-4 text-noir/80 mb-5`}>
            {article.data.resume}
          </p>

          {/* Points clés */}
          {article.data.points_cles && article.data.points_cles.length > 0 && (
            <div class="bg-noir text-blanc rounded-xl p-5 mb-2">
              <p class="font-mono text-[9px] uppercase tracking-[2px] text-blanc/50 mb-3">L'essentiel</p>
              <ul class="flex flex-col gap-2 list-none p-0 m-0">
                {article.data.points_cles.map(pt => (
                  <li class="flex items-start gap-2.5 text-[14px] leading-snug text-blanc/90">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-blanc/30 shrink-0"></span>
                    {pt}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="flex items-center gap-2 pt-4 border-t border-gris-chaud text-[11px] font-mono text-gris-clair">
            <span>Rédaction Citoyens.ai</span>
            <span>·</span>
            <span>{article.data.sources.length} source{article.data.sources.length > 1 ? 's' : ''} citée{article.data.sources.length > 1 ? 's' : ''}</span>
          </div>
        </header>

        {/* ── Citation clé (pull quote) ── */}
        {article.data.citation_cle && (
          <blockquote class={`border-l-4 ${style.border} pl-5 py-1 my-8`}>
            <p class="font-display text-[19px] md:text-[22px] font-bold leading-snug text-noir italic">
              « {article.data.citation_cle} »
            </p>
          </blockquote>
        )}

        {/* ── Corps MDX ── */}
        <div class="article-body mt-6">
          <Content />
        </div>

        {/* ── Sources ── */}
        {article.data.sources?.length > 0 && (
          <aside id="sources" class="mt-12 pt-6 border-t-2 border-noir" aria-label="Sources">
            <h2 class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-noir mb-5">
              Sources · {article.data.sources.length} références
            </h2>
            <ol class="flex flex-col gap-2.5 list-none p-0 m-0">
              {article.data.sources.map((src, i) => (
                <li class="flex items-start gap-3">
                  <span class="font-mono text-[10px] font-bold text-gris-clair bg-gris-chaud rounded px-1.5 py-0.5 shrink-0 mt-0.5 min-w-[24px] text-center">
                    {i + 1}
                  </span>
                  <a
                    href={src.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[14px] text-bleu-rep no-underline hover:underline leading-snug"
                  >
                    {src.label}
                    <span class="text-gris-clair ml-1 text-[11px]" aria-hidden="true">↗</span>
                  </a>
                </li>
              ))}
            </ol>
          </aside>
        )}

        {/* ── Nav bas de page ── */}
        <div class="mt-10 pt-5 border-t border-gris-chaud flex items-center justify-between flex-wrap gap-4">
          <a
            href={style.href}
            class={`inline-flex items-center gap-1.5 text-[13px] font-semibold no-underline ${style.color} hover:underline`}
          >
            ← {label}
          </a>
          <a href="/methodologie" class="font-mono text-[10px] text-gris-clair underline decoration-dotted hover:text-bleu-rep transition-colors">
            Méthodologie
          </a>
        </div>

      </div>

      {/* ── Sidebar ── */}
      <aside class="w-full lg:w-[240px] shrink-0 lg:sticky lg:top-24 self-start space-y-5 hidden lg:block">

        {/* Sommaire */}
        <div class="border border-gris-chaud rounded-xl p-4 bg-blanc">
          <p class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-gris-clair mb-3">Dans cet article</p>
          <nav class="flex flex-col gap-1">
            <a href="#contexte"                   class={`text-[13px] no-underline hover:underline py-0.5 ${style.color} font-semibold`}>Contexte</a>
            <a href="#les-faits"                  class="text-[13px] text-gris-texte no-underline hover:text-noir hover:underline py-0.5">Les faits</a>
            <a href="#pourquoi-cest-important"    class="text-[13px] text-gris-texte no-underline hover:text-noir hover:underline py-0.5">Pourquoi c'est important</a>
            {article.data.sources?.length > 0 && (
              <a href="#sources" class="text-[13px] text-gris-texte no-underline hover:text-noir hover:underline py-0.5">
                Sources ({article.data.sources.length})
              </a>
            )}
          </nav>
        </div>

        {/* Section */}
        <div class="border border-gris-chaud rounded-xl p-4 bg-blanc">
          <p class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-gris-clair mb-3">Section</p>
          <a
            href={style.href}
            class={`inline-flex items-center gap-1.5 text-[13px] font-semibold no-underline ${style.color} hover:underline`}
          >
            ← Retour à {label}
          </a>
        </div>

      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>
