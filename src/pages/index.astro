---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroBriefing from '../components/home/HeroBriefing.astro';
import ProfileCardGrid from '../components/home/ProfileCardGrid.astro';
import VotesRecents from '../components/home/VotesRecents.astro';
import DashboardRepublique from '../components/home/DashboardRepublique.astro';
---

<BaseLayout title="Aujourd'hui" description="Citoyens.ai — Le journal citoyen de la politique française. Décryptages, dossiers, données : comprenez ce qui se passe, formez votre propre opinion.">
  <Header />
  <main>
    <HeroBriefing />
    <DashboardRepublique />
    <VotesRecents />
    <ProfileCardGrid />
