---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import EditionDuJour from '../components/home/EditionDuJour.astro';

const uneData = await import('../data/une.json').then(m => m.default).catch(() => null);

const jsonLd: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Citoyens.ai',
  url: 'https://citoyens.ai',
  description: "L'essentiel de l'actu en 5 minutes, avec la transparence sur les sources.",
  publisher: {
    '@type': 'Organization',
    name: 'Citoyens.ai',
    url: 'https://citoyens.ai',
  },
};

if (uneData?.sujet_du_jour) {
  jsonLd.mainEntity = {
    '@type': 'NewsArticle',
    headline: uneData.sujet_du_jour.titre,
    datePublished: uneData.date,
    description: uneData.sujet_du_jour.pourquoi_important,
    publisher: { '@type': 'Organization', name: 'Citoyens.ai' },
  };
}
---

<BaseLayout title="Aujourd'hui" description={uneData?.sujet_du_jour?.titre ? `${uneData.sujet_du_jour.titre} — Citoyens.ai` : "Citoyens.ai — L'essentiel de l'actu en 5 minutes."} jsonLd={jsonLd}>
  <Header />
  <main>
    <EditionDuJour />
  </main>
  <Footer />
</BaseLayout>
