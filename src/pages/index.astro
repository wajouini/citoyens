---
import { validateUne, validateFil, validateSujetsChauds } from '../utils/validate-data';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SujetsChaudsBanner from '../components/home/SujetsChaudsBanner.astro';
import FilPreview from '../components/home/FilPreview.astro';
import IAPreview from '../components/home/IAPreview.astro';
import SoirTeaser from '../components/home/SoirTeaser.astro';
import MediaOwnerBadge from '../components/home/MediaOwnerBadge.astro';
import SourceLinks from '../components/ui/SourceLinks.astro';
import LinkedText from '../components/ui/LinkedText.astro';

const uneRaw = await import('../data/une.json').then(m => m.default).catch(() => null);
const filRaw = await import('../data/fil.json').then(m => m.default).catch(() => null);
const iaData = await import('../data/ia.json').then(m => m.default).catch(() => null);
const sujetsChaudsRaw = await import('../data/sujets-chauds.json').then(m => m.default).catch(() => null);
const soirData = await import('../data/soir.json').then(m => m.default).catch(() => null);

const uneData = validateUne(uneRaw).data;
const filData = validateFil(filRaw).data;
const sujetsChaudsData = validateSujetsChauds(sujetsChaudsRaw).data;

const sujet = uneData?.sujet_du_jour;
const france = uneData?.france || [];
const monde = uneData?.monde || [];
const essentiels = uneData?.essentiels || [];
const regardCroise = uneData?.regard_croise;
const regardEtranger = uneData?.regard_etranger || [];
const chiffre = uneData?.chiffre_du_jour;
const aSurveiller = uneData?.a_surveiller || [];
const meta = uneData?.meta;
const hasFranceMonde = france.length > 0 || monde.length > 0;

const sujetsActifs = sujetsChaudsData?.sujets_actifs || [];
const sujetsRefroidis = sujetsChaudsData?.sujets_refroidis || [];
const filItems = filData?.items || [];
const faitsIA = iaData?.faits_ia || [];

const rubriqueStyle: Record<string, { label: string; color: string; bg: string }> = {
  politique: { label: 'Politique', color: 'text-bleu-rep', bg: 'bg-bleu-clair' },
  economie: { label: 'Économie', color: 'text-orange', bg: 'bg-orange/10' },
  tech: { label: 'Tech', color: 'text-purple-700', bg: 'bg-purple-50' },
  science: { label: 'Science', color: 'text-vert', bg: 'bg-green-50' },
  societe: { label: 'Société', color: 'text-rouge-doux', bg: 'bg-red-50' },
  culture: { label: 'Culture', color: 'text-amber-700', bg: 'bg-amber-50' },
  international: { label: 'International', color: 'text-sky-700', bg: 'bg-sky-50' },
  ia: { label: 'IA', color: 'text-indigo-700', bg: 'bg-indigo-50' },
};

const tonBadge: Record<string, { label: string; cls: string }> = {
  critique: { label: 'Critique', cls: 'bg-rouge-doux/10 text-rouge-doux' },
  factuel: { label: 'Factuel', cls: 'bg-bleu-clair text-bleu-rep' },
  alarmiste: { label: 'Alarmiste', cls: 'bg-orange/10 text-orange' },
  complaisant: { label: 'Complaisant', cls: 'bg-amber-50 text-amber-700' },
  neutre: { label: 'Neutre', cls: 'bg-gray-100 text-gris-texte' },
  engage: { label: 'Engagé', cls: 'bg-purple-50 text-purple-700' },
};

const sourceTypeBg: Record<string, string> = {
  investigation: 'border-l-orange',
  mainstream: 'border-l-bleu-rep',
  'fact-check': 'border-l-vert',
  etranger: 'border-l-purple-600',
  institutionnel: 'border-l-gris-clair',
};

const paysEmoji: Record<string, string> = {
  'Royaume-Uni': '🇬🇧', 'Allemagne': '🇩🇪', 'Etats-Unis': '🇺🇸', 'États-Unis': '🇺🇸',
  'Espagne': '🇪🇸', 'Italie': '🇮🇹', 'Belgique': '🇧🇪', 'Suisse': '🇨🇭',
  'Canada': '🇨🇦', 'Japon': '🇯🇵', 'Qatar': '🇶🇦', 'Europe': '🇪🇺',
  'France': '🇫🇷', 'Brésil': '🇧🇷', 'Australie': '🇦🇺', 'Inde': '🇮🇳',
  'Chine': '🇨🇳', 'Russie': '🇷🇺', 'Israël': '🇮🇱', 'Palestine': '🇵🇸',
  'Turquie': '🇹🇷', 'Maroc': '🇲🇦', 'Algérie': '🇩🇿', 'Pakistan': '🇵🇰',
  'Afghanistan': '🇦🇫', 'Ukraine': '🇺🇦', 'Corée du Sud': '🇰🇷',
};

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
};

const jsonLd: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Citoyens.ai',
  url: 'https://citoyens.ai',
  description: "L'essentiel de l'actu en 5 minutes, avec la transparence sur les sources.",
  publisher: {
    '@type': 'Organization',
    name: 'Citoyens.ai',
    url: 'https://citoyens.ai',
  },
};

if (sujet) {
  jsonLd.mainEntity = {
    '@type': 'NewsArticle',
    headline: sujet.titre,
    datePublished: uneData.date,
    description: sujet.pourquoi_important,
    publisher: { '@type': 'Organization', name: 'Citoyens.ai' },
  };
}
---

<BaseLayout title="Aujourd'hui" description={sujet?.titre ? `${sujet.titre} — Citoyens.ai` : "Citoyens.ai — L'essentiel de l'actu en 5 minutes."} jsonLd={jsonLd}>
  <Header />

  {/* ── EN DIRECT / SUJETS CHAUDS ── */}
  <SujetsChaudsBanner sujets={sujetsActifs} sujetsRefroidis={sujetsRefroidis} />

  <main class="max-w-[1280px] mx-auto px-4 md:px-6 py-6 md:py-10">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
      {/* Colonne Principale */}
      <div class="flex-1 lg:w-[65%] min-w-0">

      {/* ── DATE ── */}
      {uneData && (
        <div class="flex items-center gap-3 mb-6 md:mb-8 pt-6 md:pt-8">
          <div class="font-mono text-[10px] md:text-[11px] uppercase tracking-[2px] text-bleu-rep font-bold">Édition du jour</div>
          <div class="flex-1 h-px bg-gris-chaud"></div>
          <div class="font-mono text-[10px] md:text-[11px] text-gris-clair">{uneData.date && formatDate(uneData.date)}</div>
        </div>
      )}

      {/* ── 1. SUJET DU JOUR (hero) ── */}
      {sujet && (
        <section class="mb-14">
          <div class="flex items-center gap-2 mb-3">
            <span class="font-mono text-[9px] font-bold uppercase tracking-[2px] text-white bg-noir px-2 py-0.5 rounded">Sujet du jour</span>
            {rubriqueStyle[sujet.rubrique] && (
              <span class={`font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${rubriqueStyle[sujet.rubrique].bg} ${rubriqueStyle[sujet.rubrique].color}`}>
                {rubriqueStyle[sujet.rubrique].label}
              </span>
            )}
          </div>
          <h1 class="font-display text-[26px] md:text-[40px] font-black leading-[1.12] tracking-tight text-noir mb-3">
            {sujet.titre}
          </h1>
          <p class="text-[15px] md:text-[17px] font-semibold text-bleu-rep leading-snug mb-4">
            {sujet.pourquoi_important}
          </p>
          {sujet.faits?.length > 0 && (
            <ul class="flex flex-col gap-1.5 mb-4">
              {sujet.faits.map((fait: string) => (
                <li class="flex items-start gap-2 text-[15px] text-noir leading-relaxed">
                  <span class="text-bleu-rep mt-1 shrink-0 font-bold">•</span>
                  <span><LinkedText text={fait} sources={sujet.sources} /></span>
                </li>
              ))}
            </ul>
          )}
          <p class="text-[15px] leading-relaxed text-gris-texte mb-4">
            <LinkedText text={sujet.contexte || ''} sources={sujet.sources} />
          </p>
          {sujet.sources?.length > 0 && (
            <SourceLinks sources={sujet.sources} />
          )}
        </section>
      )}

      {/* ── DIVIDER ── */}
      <div class="h-px bg-gris-chaud mb-8"></div>

      {/* ── 3. FRANCE ── */}
      {hasFranceMonde ? (
        <>
          {france.length > 0 && (
            <section id="section-france" class="mb-12">
              <div class="flex items-center gap-2 mb-6">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-bleu-rep">🇫🇷 France</span>
                <div class="flex-1 h-px bg-bleu-rep/20"></div>
              </div>
              <div class="flex flex-col gap-0">
                {france.map((item: any) => {
                  const style = rubriqueStyle[item.rubrique] || rubriqueStyle.politique;
                  return (
                    <div class="py-4 border-b border-gris-chaud last:border-0">
                      <div class="flex items-center gap-2 mb-1.5">
                        <span class={`font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${style.bg} ${style.color}`}>
                          {style.label}
                        </span>
                        {item.sources?.length > 1 && (
                          <span class="font-mono text-[9px] text-gris-clair bg-gris-chaud px-1.5 py-0.5 rounded">
                            {item.sources.length} sources
                          </span>
                        )}
                      </div>
                      <h3 class="font-display text-[17px] font-bold text-noir leading-snug mb-1">
                        {item.titre}
                      </h3>
                      <p class="text-[14px] text-gris-texte leading-relaxed mb-2"><LinkedText text={item.resume || ''} sources={item.sources} /></p>
                      {item.sources?.length > 0 && (
                        <SourceLinks sources={item.sources} compact={true} />
                      )}
                    </div>
                  );
                })}
              </div>
            </section>
          )}

          {/* ── 4. MONDE ── */}
          {monde.length > 0 && (
            <section id="section-monde" class="mb-12">
              <div class="flex items-center gap-2 mb-6">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-sky-700">🌍 Monde</span>
                <div class="flex-1 h-px bg-sky-700/20"></div>
              </div>
              <div class="flex flex-col gap-0">
                {monde.map((item: any) => (
                  <div class="py-4 border-b border-gris-chaud last:border-0">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded bg-sky-50 text-sky-700">
                        {paysEmoji[item.pays] || '🌐'} {item.pays}
                      </span>
                    </div>
                    <h3 class="font-display text-[17px] font-bold text-noir leading-snug mb-1">
                      {item.titre}
                    </h3>
                    <p class="text-[14px] text-gris-texte leading-relaxed mb-2"><LinkedText text={item.resume || ''} sources={item.sources} /></p>
                    {item.sources?.length > 0 && (
                      <SourceLinks sources={item.sources} compact={true} />
                    )}
                  </div>
                ))}
              </div>
            </section>
          )}

          {/* ── VU DE L'ÉTRANGER ── */}
          {regardEtranger.length > 0 && (
            <section class="mb-8">
              <div class="flex items-center gap-2 mb-4">
                <span class="font-mono text-[9px] font-bold uppercase tracking-[2px] text-purple-700 bg-purple-50 px-2 py-0.5 rounded">Vu de l'étranger</span>
                <span class="font-mono text-[9px] text-gris-clair">La France vue d'ailleurs</span>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                {regardEtranger.map((r: any) => (
                  <a href={r.url} target="_blank" rel="noopener noreferrer"
                     class="block p-3.5 rounded-lg border border-gris-chaud bg-blanc no-underline hover:border-purple-300 hover:shadow-sm transition-all group">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="text-base">{paysEmoji[r.pays] || '🌐'}</span>
                      <span class="font-mono text-[11px] font-bold text-noir">{r.source}</span>
                      {r.groupe_media && <MediaOwnerBadge groupe_media={r.groupe_media} compact={true} />}
                    </div>
                    <p class="text-[13px] font-semibold text-noir leading-snug mb-1 group-hover:text-purple-700 transition-colors">
                      {r.titre}
                    </p>
                    <p class="text-[12px] text-gris-texte leading-relaxed line-clamp-2">{r.angle}</p>
                  </a>
                ))}
              </div>
            </section>
          )}
        </>
      ) : essentiels.length > 0 && (
        <section class="mb-10">
          <h2 class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-noir mb-5">Les essentiels</h2>
          <div class="flex flex-col gap-0">
            {essentiels.map((item: any) => {
              const style = rubriqueStyle[item.rubrique] || rubriqueStyle.politique;
              return (
                <div class="py-4 border-b border-gris-chaud last:border-0">
                  <div class="flex items-center gap-2 mb-1.5">
                    <span class={`font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${style.bg} ${style.color}`}>
                      {style.label}
                    </span>
                  </div>
                  <h3 class="font-display text-[17px] font-bold text-noir leading-snug mb-1">
                    {item.titre}
                  </h3>
                  <p class="text-[14px] text-gris-texte leading-relaxed mb-2">{item.resume}</p>
                  {item.sources?.length > 0 && (
                    <SourceLinks sources={item.sources} compact={true} />
                  )}
                </div>
              );
            })}
          </div>
        </section>
      )}

      {/* ── DIVIDER ── */}
      <div class="h-px bg-gris-chaud mb-8"></div>

      {/* ── 5. IA / TECH PREVIEW ── */}
      {faitsIA.length > 0 && (
        <IAPreview faits={faitsIA} />
      )}

      {/* ── 6. REGARD CROISÉ ── */}
      {regardCroise && (
        <section id="section-regard-croise" class="mb-14">
          <div class="flex items-center gap-2 mb-6">
            <span class="font-mono text-[9px] font-bold uppercase tracking-[2px] text-rouge-doux bg-red-50 px-2 py-0.5 rounded">Regard croisé</span>
            {rubriqueStyle[regardCroise.rubrique] && (
              <span class={`font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${rubriqueStyle[regardCroise.rubrique].bg} ${rubriqueStyle[regardCroise.rubrique].color}`}>
                {rubriqueStyle[regardCroise.rubrique].label}
              </span>
            )}
          </div>
          <h2 class="font-display text-[24px] md:text-[28px] font-black leading-tight mb-3 text-noir">
            {regardCroise.sujet}
          </h2>
          <p class="text-[15px] leading-relaxed text-gris-texte mb-5">
            {regardCroise.contexte}
          </p>

          <div class="border-2 border-noir rounded-xl p-4 mb-5 bg-blanc">
            <h4 class="font-mono text-[9px] uppercase tracking-[2px] text-noir mb-1.5">Ce qu'il faut retenir</h4>
            <p class="text-[15px] leading-relaxed text-noir font-medium">
              {regardCroise.ce_quil_faut_retenir || (regardCroise as any).verdict_citoyens}
            </p>
          </div>

          <details class="group mb-4">
            <summary class="cursor-pointer font-mono text-[11px] font-bold uppercase tracking-wider text-bleu-rep hover:underline list-none flex items-center gap-1.5">
              <span class="group-open:rotate-90 transition-transform">▸</span>
              Voir les {regardCroise.couvertures?.length || 0} couvertures détaillées
            </summary>
            <div class="mt-4 flex flex-col gap-3">
              {regardCroise.couvertures?.map((c: any) => (
                <a href={c.url} target="_blank" rel="noopener noreferrer"
                   class={`block p-3.5 rounded-lg border border-gris-chaud border-l-4 ${sourceTypeBg[c.type] || 'border-l-gris-clair'} bg-blanc no-underline hover:shadow-md transition-shadow group/card`}>
                  <div class="flex items-center gap-2 mb-1 flex-wrap">
                    <span class="font-mono text-[12px] font-bold text-noir">{c.source}</span>
                    {tonBadge[c.ton] && (
                      <span class={`text-[9px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded-full ${tonBadge[c.ton].cls}`}>
                        {tonBadge[c.ton].label}
                      </span>
                    )}
                    {c.groupe_media && <MediaOwnerBadge groupe_media={c.groupe_media} compact={true} />}
                  </div>
                  <p class="text-[14px] leading-snug text-noir font-semibold mb-1 group-hover/card:text-bleu-rep transition-colors">
                    {c.angle}
                  </p>
                  {c.citation_cle && (
                    <p class="text-[12px] text-gris-texte italic leading-relaxed mt-1.5 border-t border-gris-chaud/50 pt-1.5">
                      « {c.citation_cle} »
                    </p>
                  )}
                </a>
              ))}
            </div>
          </details>

          <details class="group mb-4">
            <summary class="cursor-pointer font-mono text-[11px] font-bold uppercase tracking-wider text-bleu-rep hover:underline list-none flex items-center gap-1.5">
              <span class="group-open:rotate-90 transition-transform">▸</span>
              Analyse de cohérence
            </summary>
            <div class="mt-3 bg-bleu-clair rounded-xl p-4">
              <p class="text-[14px] leading-relaxed text-noir">
                {regardCroise.analyse_coherence}
              </p>
              {regardCroise.biais_detectes?.length > 0 && (
                <div class="mt-3 pt-3 border-t border-bleu-rep/10">
                  <h5 class="font-mono text-[9px] uppercase tracking-[2px] text-rouge-doux mb-1.5">Biais détectés</h5>
                  <ul class="flex flex-col gap-1">
                    {regardCroise.biais_detectes.map((b: string) => (
                      <li class="flex items-start gap-1.5 text-[13px] text-gris-texte leading-snug">
                        <span class="text-rouge-doux mt-0.5 shrink-0">•</span>
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </details>

          <p class="font-mono text-[9px] text-gris-clair mt-2">
            <a href="/methodologie" class="underline hover:text-bleu-rep">Notre méthodologie</a>
          </p>
        </section>
      )}

      {/* ── 7. CHIFFRE + À SURVEILLER ── */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-14">
        {chiffre && (
          <div class="bg-noir text-white rounded-xl p-5">
            <div class="font-mono text-[9px] uppercase tracking-[2px] text-white/50 mb-2">Le chiffre du jour</div>
            <div class="font-mono text-[38px] font-bold leading-none mb-2 text-white">{chiffre.valeur}</div>
            <p class="text-[14px] leading-relaxed text-white/80 mb-2">{chiffre.contexte}</p>
            <a href={chiffre.source_url} target="_blank" rel="noopener noreferrer" class="text-[10px] text-white/40 font-mono no-underline hover:text-white/70 transition-colors">
              Source : {chiffre.source} ↗
            </a>
          </div>
        )}

        {aSurveiller.length > 0 && (
          <div class="border border-orange/20 rounded-xl p-5 bg-orange/5">
            <h3 class="font-mono text-[9px] uppercase tracking-[2px] text-orange mb-3 pb-2 border-b border-orange/20">
              À surveiller
            </h3>
            <div class="flex flex-col gap-2">
              {aSurveiller.map((evt: any) => (
                <div class="flex gap-2 items-start">
                  <span class="font-mono text-[10px] text-orange/60 shrink-0 mt-0.5">
                    {new Date(evt.date + 'T00:00:00').toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })}
                  </span>
                  <span class="text-[13px] text-gris-texte leading-snug">{evt.evenement}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* ── 8. ÉDITION DU SOIR TEASER ── */}
      <SoirTeaser soirData={soirData} />

      {/* ── BADGE DE CONFIANCE ── */}
      {meta && (
        <div class="flex flex-wrap items-center justify-center gap-3 pb-8 border-t border-gris-chaud pt-5 mt-2">
          <div class="flex items-center gap-1.5 bg-vert/10 border border-vert/20 rounded-full px-3 py-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-vert"></span>
            <span class="font-mono text-[10px] text-vert font-semibold">{meta.nb_articles_analyses} sources analysées</span>
          </div>
          <div class="flex items-center gap-1.5 bg-bleu-clair border border-bleu-rep/15 rounded-full px-3 py-1.5">
            <span class="font-mono text-[10px] text-bleu-rep">{meta.sources_francaises} sources FR · {meta.sources_etrangeres} internationales</span>
          </div>
          {uneData?.genere_a && (
            <div class="flex items-center gap-1.5 bg-gris-chaud/50 rounded-full px-3 py-1.5">
              <span class="font-mono text-[10px] text-gris-clair">
                Généré le {new Date(uneData.genere_a).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
              </span>
            </div>
          )}
        </div>
      )}
      </div> {/* End Main Column */}

      {/* Colonne Latérale (Sidebar) */}
      <aside class="w-full lg:w-[35%] xl:w-[30%] lg:sticky lg:top-24 self-start space-y-8">
        {/* ── 2. FIL CONTINU PREVIEW ── */}
        {filItems.length > 0 && (
          <FilPreview items={filItems} generatedAt={filData?.genere_a} derniereMaj={(filData as any)?.derniere_maj} filDate={filData?.date} />
        )}
      </aside>

    </div> {/* End Flex Container */}
  </main>
  <Footer />
</BaseLayout>

<script>
  function relativeTime(isoStr: string): string {
    const diff = Date.now() - new Date(isoStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return "à l'instant";
    if (mins < 60) return `il y a ${mins}min`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `il y a ${hours}h`;
    return `il y a ${Math.floor(hours / 24)}j`;
  }

  function updateTimestamps() {
    document.querySelectorAll<HTMLElement>('[data-fil-timestamp]').forEach(el => {
      const iso = el.getAttribute('data-fil-timestamp');
      if (iso) el.textContent = `MAJ ${relativeTime(iso)}`;
    });
  }

  updateTimestamps();
  setInterval(updateTimestamps, 60_000);

  async function refreshFil() {
    try {
      const res = await fetch('/data/fil.json');
      if (!res.ok) return;
      const data = await res.json();
      const items = data?.items?.slice(0, 6);
      if (!items?.length) return;

      const container = document.getElementById('fil-items');
      if (!container) return;

      const rubriqueColor: Record<string, string> = {
        politique: 'text-bleu-rep',
        economie: 'text-orange',
        tech: 'text-purple-700',
        science: 'text-vert',
        societe: 'text-rouge-doux',
        culture: 'text-amber-700',
        international: 'text-sky-700',
        ia: 'text-indigo-700',
      };
      const rubriqueLabel: Record<string, string> = {
        politique: 'Politique',
        economie: 'Économie',
        tech: 'Tech',
        science: 'Science',
        societe: 'Société',
        culture: 'Culture',
        international: 'International',
        ia: 'IA',
      };

      container.innerHTML = items.map((item: any) => {
        const color = rubriqueColor[item.rubrique] || 'text-bleu-rep';
        const label = rubriqueLabel[item.rubrique] || item.rubrique;
        const itemUrl = item.url || item.source_url;
        const itemTitle = item.titre || item.texte;
        const titleHtml = itemUrl
          ? `<a href="${itemUrl}" target="_blank" rel="noopener noreferrer" class="block text-[13px] text-noir leading-snug no-underline hover:text-bleu-rep transition-colors line-clamp-2">${itemTitle}</a>`
          : `<p class="text-[13px] text-noir leading-snug line-clamp-2">${itemTitle}</p>`;
        return `<div class="flex gap-3 px-4 py-3 border-b border-gris-chaud last:border-0">
          <div class="shrink-0 pt-0.5">
            <span class="font-mono text-[11px] font-bold text-gris-clair">${item.heure}</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-0.5">
              <span class="font-mono text-[9px] font-bold uppercase tracking-wider ${color}">${label}</span>
              <a href="${itemUrl || '#'}" target="_blank" rel="noopener noreferrer"
                 class="font-mono text-[9px] text-gris-clair no-underline hover:text-bleu-rep transition-colors">
                ${item.source} ↗
              </a>
            </div>
            ${titleHtml}
          </div>
        </div>`;
      }).join('');

      const tsEl = document.querySelector('[data-fil-timestamp]');
      if (tsEl && data.genere_a) {
        tsEl.setAttribute('data-fil-timestamp', data.genere_a);
        tsEl.textContent = `MAJ ${relativeTime(data.genere_a)}`;
      }
    } catch {
      // silently fail on refresh
    }
  }

  // Refresh every 15 minutes
  setInterval(refreshFil, 15 * 60_000);
</script>
