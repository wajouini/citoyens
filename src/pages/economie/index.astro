---
import { getCollection } from 'astro:content';
import { dedupBriefings, dedupArticles, getTopicsForSection } from '../../utils/section-data';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import FilSidebar from '../../components/section/FilSidebar.astro';

// ── Articles MDX ───────────────────────────────────────────────────────────
const allArticles = await getCollection('articles');
const rawArticles = allArticles
  .filter(a => a.data.rubrique === 'economie')
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
const articles = dedupArticles(rawArticles);

const hero = articles.find(a => a.data.estUne) ?? articles[0];
const rest = articles.filter(a => a.id !== hero?.id);

// ── Données pipeline ────────────────────────────────────────────────────────
const uneRaw = await import('../../data/une.json').then(m => m.default).catch(() => null);
const sujetsRaw = await import('../../data/sujets-chauds.json').then(m => m.default).catch(() => null);

// ── Déduplication ──────────────────────────────────────────────────────────
const coveredTitles = articles.map(a => a.data.titre);

const franceCandidates = (uneRaw?.france ?? []).filter((i: any) =>
  ['economie', 'social', 'societe'].includes(i.rubrique) && i.titre
);
const sujetsCandidates = (sujetsRaw?.sujets_actifs ?? []).filter((s: any) =>
  s.rubrique === 'economie' && s.titre
);

const briefingsFrance = dedupBriefings(franceCandidates, coveredTitles).slice(0, 5);
const sujetsActifs = dedupBriefings(
  sujetsCandidates,
  [...coveredTitles, ...briefingsFrance.map((b: any) => b.titre)]
).slice(0, 3);

// ── Fil sidebar — topics importants économie/société ────────────────────────
const topicsData = await import('../../data/.pipeline/topics-tagged.json').then(m => m.default).catch(() =>
  import('../../data/.pipeline/topics.json').then(m => m.default).catch(() => null)
);
const pipelineArticles = await import('../../data/.pipeline/raw-articles.json').then(m => m.default).catch(() => []);
const filItems = topicsData
  ? getTopicsForSection(topicsData, pipelineArticles, ['macro', 'taxe', 'industrie', 'automobile', 'transport', 'energie', 'immobilier', 'travail', 'salaire', 'investissement', 'ecologie'], 7)
  : [];

const uneDate: string | undefined = uneRaw?.date as string | undefined;

const formatDate = (d: string) =>
  new Date(d + 'T00:00:00').toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'long', year: 'numeric',
  });

const formatDateShort = (d: string) =>
  new Date(d + 'T00:00:00').toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'short',
  });
---

<BaseLayout
  title="Économie — Citoyens.ai"
  description="Décryptage de l'actualité économique : budget, dette, emploi, industrie. Contexte, faits, enjeux — avec toutes les sources."
>
  <Header />

  <main class="max-w-[1280px] mx-auto px-4 md:px-6 py-8 md:py-12">

    <div class="flex items-center gap-4 mb-10 pb-4 border-b-2 border-orange">
      <h1 class="font-display text-[32px] md:text-[40px] font-black text-noir tracking-tight">Économie</h1>
      <span class="font-mono text-[11px] uppercase tracking-[2px] text-orange bg-orange/10 px-2.5 py-1 rounded">
        Analyse & décryptage
      </span>
    </div>

    <div class="flex flex-col lg:flex-row gap-10 lg:gap-14">

      {/* ── Colonne principale ── */}
      <div class="flex-1 min-w-0 space-y-14">

        {/* Articles de fond */}
        {articles.length > 0 && (
          <section>
            <div class="flex items-center gap-2 mb-6">
              <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-gris-clair">Analyses de fond</span>
              <div class="flex-1 h-px bg-gris-chaud"></div>
            </div>

            {hero && (
              <a href={`/article/${hero.id}`} class="block group no-underline mb-8">
                <div class="border-l-4 border-orange pl-5">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-orange bg-orange/10 px-2 py-0.5 rounded">À la une</span>
                    <time class="font-mono text-[11px] text-gris-clair">{formatDate(hero.data.date)}</time>
                  </div>
                  <h2 class="font-display text-[26px] md:text-[32px] font-black text-noir leading-[1.1] tracking-tight mb-3 group-hover:text-orange transition-colors">
                    {hero.data.titre}
                  </h2>
                  <p class="text-[16px] text-gris-texte leading-relaxed mb-4 max-w-[640px]">{hero.data.resume}</p>
                  <span class="inline-flex items-center gap-1 font-mono text-[12px] text-orange font-semibold group-hover:underline">Lire l'article →</span>
                </div>
              </a>
            )}

            {rest.length > 0 && (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                {rest.map(a => (
                  <a href={`/article/${a.id}`} class="block group no-underline p-5 rounded-xl border border-gris-chaud bg-blanc hover:border-orange/30 hover:shadow-md transition-all">
                    <time class="font-mono text-[10px] text-gris-clair block mb-2">{formatDateShort(a.data.date)}</time>
                    <h3 class="font-display text-[18px] font-bold text-noir leading-snug mb-2 group-hover:text-orange transition-colors">{a.data.titre}</h3>
                    <p class="text-[13px] text-gris-texte leading-relaxed line-clamp-3">{a.data.resume}</p>
                    <span class="inline-block mt-3 font-mono text-[11px] text-orange font-semibold group-hover:underline">Lire →</span>
                  </a>
                ))}
              </div>
            )}
          </section>
        )}

        {/* Briefing du jour — sujets économiques non couverts */}
        {briefingsFrance.length > 0 && (
          <section>
            <div class="flex items-center gap-3 mb-6">
              <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-gris-clair">Briefing du jour</span>
              <div class="flex-1 h-px bg-gris-chaud"></div>
              {uneDate && <time class="font-mono text-[10px] text-gris-clair shrink-0">{formatDate(uneDate)}</time>}
            </div>
            <div class="space-y-4">
              {briefingsFrance.map((item: any) => (
                <div class="p-4 rounded-xl border border-gris-chaud bg-blanc">
                  <h3 class="font-display text-[17px] font-bold text-noir leading-snug mb-2">{item.titre}</h3>
                  <p class="text-[13px] text-gris-texte leading-relaxed mb-3">{item.resume}</p>
                  {item.sources?.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {item.sources.slice(0, 4).map((s: any) => (
                        <a href={s.url} target="_blank" rel="noopener noreferrer"
                          class="inline-flex items-center gap-1 font-mono text-[10px] text-orange bg-orange/10 px-2 py-0.5 rounded no-underline hover:underline">
                          {s.nom} ↗
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

        {/* Sujets suivis */}
        {sujetsActifs.length > 0 && (
          <section>
            <div class="flex items-center gap-2 mb-6">
              <span class="font-mono text-[10px] font-bold uppercase tracking-[2px] text-gris-clair">Sujets suivis</span>
              <div class="flex-1 h-px bg-gris-chaud"></div>
            </div>
            <div class="space-y-3">
              {sujetsActifs.map((sujet: any) => (
                <div class="p-4 rounded-xl border border-orange/30 bg-blanc">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-orange animate-pulse"></span>
                    <span class="font-mono text-[9px] font-bold uppercase tracking-[2px] text-orange">En cours</span>
                  </div>
                  <h3 class="font-display text-[15px] font-bold text-noir leading-snug mb-1">{sujet.titre}</h3>
                  <p class="text-[12px] text-gris-texte leading-relaxed">{sujet.resume}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        {articles.length === 0 && briefingsFrance.length === 0 && (
          <div class="py-20 text-center text-gris-clair font-mono text-[13px]">Contenu en cours de génération…</div>
        )}

      </div>

      {/* ── Sidebar ── */}
      <aside class="w-full lg:w-[300px] shrink-0 lg:sticky lg:top-24 self-start">
        <FilSidebar
          items={filItems}
          label="Sujets du moment"
          accentColor="text-orange"
          dotColor="bg-orange"
          headerBg="bg-orange/5"
        />
      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>
