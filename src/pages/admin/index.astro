---
/**
 * Static status page — minimal public dashboard.
 * Full admin interface is at the Next.js app (npm run dev in /admin).
 * This page shows a read-only summary for quick reference.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import uneData from '../../data/une.json';

let runs: any[] = [];
try {
  const runsModule = await import('../../data/.pipeline/runs.json');
  runs = Array.isArray(runsModule.default) ? runsModule.default : [];
} catch { /* no runs yet */ }

const lastRun = runs.length > 0 ? runs[runs.length - 1] : null;
const successRuns = runs.filter(r => r.status === 'success').length;
const totalRuns = runs.length;
const successRate = totalRuns > 0 ? Math.round((successRuns / totalRuns) * 100) : 0;

const uneDate = (uneData as any).date || '—';
const uneTitre = (uneData as any).titre_une || '—';

const formatDate = (iso: string) => {
  try {
    return new Date(iso).toLocaleString('fr-FR', {
      day: '2-digit', month: '2-digit', year: 'numeric',
      hour: '2-digit', minute: '2-digit',
    });
  } catch { return iso; }
};

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'http://localhost:3000';
---

<BaseLayout title="Statut — Citoyens.ai" description="Statut du pipeline Citoyens.ai">
  <div class="bg-noir text-white py-2 text-[11px] tracking-wider uppercase font-medium">
    <div class="max-w-[1400px] mx-auto px-6 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <a href="/" class="text-white no-underline font-display text-lg font-black">citoyens<span class="text-bleu-clair">.ai</span></a>
        <span class="opacity-40">|</span>
        <span class="text-orange font-mono">Statut Pipeline</span>
      </div>
      <div class="flex items-center gap-4">
        <a href={ADMIN_URL} class="text-bleu-clair no-underline hover:underline font-mono text-[12px]">Ouvrir l'admin complet →</a>
        <a href="/" class="text-bleu-clair no-underline hover:underline">← Retour au site</a>
      </div>
    </div>
  </div>

  <main class="bg-creme min-h-screen">
    <div class="max-w-[800px] mx-auto px-6 py-12">
      <div class="text-center mb-10">
        <h1 class="font-display text-[28px] font-black text-noir tracking-tight">Statut du pipeline</h1>
        <p class="text-gris-texte text-[14px] mt-2">
          Vue publique en lecture seule · <a href={ADMIN_URL} class="text-bleu-rep no-underline hover:underline">Accéder à l'admin complet</a>
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-blanc rounded-xl border border-gris-chaud p-4 text-center">
          <div class="font-mono text-[9px] uppercase tracking-[2px] text-gris-clair mb-2">Dernier run</div>
          {lastRun ? (
            <div class="flex items-center justify-center gap-2">
              <span class={`w-2.5 h-2.5 rounded-full ${lastRun.status === 'success' ? 'bg-vert' : 'bg-rouge-doux'}`}></span>
              <span class="font-mono text-[15px] font-bold text-noir">{lastRun.status === 'success' ? 'OK' : 'FAIL'}</span>
            </div>
          ) : (
            <span class="font-mono text-[15px] text-gris-clair">Aucun</span>
          )}
          {lastRun && <div class="font-mono text-[10px] text-gris-clair mt-1">{formatDate(lastRun.started_at)}</div>}
        </div>
        <div class="bg-blanc rounded-xl border border-gris-chaud p-4 text-center">
          <div class="font-mono text-[9px] uppercase tracking-[2px] text-gris-clair mb-2">Total runs</div>
          <div class="font-mono text-[22px] font-bold text-noir leading-none">{totalRuns}</div>
        </div>
        <div class="bg-blanc rounded-xl border border-gris-chaud p-4 text-center">
          <div class="font-mono text-[9px] uppercase tracking-[2px] text-gris-clair mb-2">Taux succès</div>
          <div class={`font-mono text-[22px] font-bold leading-none ${successRate >= 80 ? 'text-vert' : successRate >= 50 ? 'text-orange' : 'text-rouge-doux'}`}>
            {totalRuns > 0 ? `${successRate}%` : '—'}
          </div>
        </div>
        <div class="bg-blanc rounded-xl border border-gris-chaud p-4 text-center">
          <div class="font-mono text-[9px] uppercase tracking-[2px] text-gris-clair mb-2">Édition</div>
          <div class="font-mono text-[13px] font-bold text-noir leading-tight">{uneDate}</div>
        </div>
      </div>

      {uneTitre !== '—' && (
        <div class="bg-blanc rounded-xl border border-gris-chaud p-6 mb-8">
          <div class="font-mono text-[10px] uppercase tracking-[2px] text-gris-clair mb-2">Dernière édition</div>
          <h2 class="font-display text-xl font-bold text-noir">{uneTitre}</h2>
        </div>
      )}

      <div class="bg-bleu-rep rounded-xl p-6 text-center">
        <p class="text-white/80 text-[14px] mb-3">Pour gérer le pipeline, modifier les sources et relire les éditions :</p>
        <a href={ADMIN_URL} class="inline-block bg-white text-bleu-rep font-mono text-[14px] font-bold px-6 py-3 rounded-lg no-underline hover:opacity-90 transition-opacity">
          Ouvrir l'admin complet
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
