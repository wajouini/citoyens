---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout title="À propos" description="Citoyens.ai est une initiative citoyenne indépendante pour la transparence de la vie publique française.">
  <Header />

  <main class="max-w-[800px] mx-auto px-6 py-12">
    <h1 class="font-display text-4xl font-black mb-8">À propos de Citoyens.ai</h1>

    <div class="space-y-6 text-[15px] text-gris-texte leading-relaxed">
      <section class="bg-blanc border border-gris-chaud rounded-lg p-6">
        <h2 class="font-display text-xl font-bold text-noir mb-3">Notre mission</h2>
        <p>
          Citoyens.ai est une plateforme citoyenne indépendante qui rend l'information politique accessible, vérifiable et comparable. Nous croisons les sources, suivons l'activité parlementaire et profilons les acteurs de la vie publique — pour que chaque citoyen puisse se forger une opinion éclairée.
        </p>
      </section>

      <section class="bg-blanc border border-gris-chaud rounded-lg p-6">
        <h2 class="font-display text-xl font-bold text-noir mb-3">Ce que nous faisons</h2>
        <ul class="space-y-2 list-none p-0 m-0">
          <li class="flex gap-2"><span class="text-bleu-rep font-bold">&bull;</span> Suivi en temps réel des votes et travaux parlementaires</li>
          <li class="flex gap-2"><span class="text-bleu-rep font-bold">&bull;</span> Fiches profils détaillées des élus et acteurs médiatiques</li>
          <li class="flex gap-2"><span class="text-bleu-rep font-bold">&bull;</span> Comparaison des couvertures médiatiques sur un même sujet</li>
          <li class="flex gap-2"><span class="text-bleu-rep font-bold">&bull;</span> Score de cohérence entre discours publics et votes effectifs</li>
          <li class="flex gap-2"><span class="text-bleu-rep font-bold">&bull;</span> Tableau de bord des indicateurs clés de la République</li>
        </ul>
      </section>

      <section class="bg-blanc border border-gris-chaud rounded-lg p-6">
        <h2 class="font-display text-xl font-bold text-noir mb-3">Nos principes</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">
          <div class="text-center p-3">
            <div class="font-mono text-2xl text-bleu-rep mb-2">0 &euro;</div>
            <div class="text-sm font-semibold text-noir">Zéro publicité</div>
            <div class="text-xs text-gris-clair mt-1">Aucun annonceur, aucun financement partisan</div>
          </div>
          <div class="text-center p-3">
            <div class="font-mono text-2xl text-bleu-rep mb-2">100%</div>
            <div class="text-sm font-semibold text-noir">Open source</div>
            <div class="text-xs text-gris-clair mt-1">Code, données et méthodologie publics</div>
          </div>
          <div class="text-center p-3">
            <div class="font-mono text-2xl text-bleu-rep mb-2">24/7</div>
            <div class="text-sm font-semibold text-noir">Données ouvertes</div>
            <div class="text-xs text-gris-clair mt-1">Sources institutionnelles vérifiables</div>
          </div>
        </div>
      </section>

      <section class="bg-blanc border border-gris-chaud rounded-lg p-6">
        <h2 class="font-display text-xl font-bold text-noir mb-3">Sources de données</h2>
        <p class="mb-3">Toutes nos données proviennent de sources publiques et institutionnelles :</p>
        <ul class="space-y-1.5 list-none p-0 m-0 text-sm">
          <li class="flex gap-2"><span class="text-vert">&check;</span> data.assemblee-nationale.fr — Votes, amendements, débats</li>
          <li class="flex gap-2"><span class="text-vert">&check;</span> data.senat.fr — Travaux du Sénat</li>
          <li class="flex gap-2"><span class="text-vert">&check;</span> NosDeputes.fr / NosSenateurs.fr — Activité parlementaire</li>
          <li class="flex gap-2"><span class="text-vert">&check;</span> HATVP — Déclarations de patrimoine et d'intérêts</li>
          <li class="flex gap-2"><span class="text-vert">&check;</span> INSEE / data.gouv.fr — Statistiques nationales</li>
          <li class="flex gap-2"><span class="text-vert">&check;</span> Arcom — Régulation des médias audiovisuels</li>
        </ul>
      </section>

      <section class="bg-blanc border border-gris-chaud rounded-lg p-6">
        <h2 class="font-display text-xl font-bold text-noir mb-3">Statut juridique</h2>
        <p>
          Citoyens.ai est une association loi 1901, déclarée en préfecture. L'association ne perçoit aucun financement public ni privé de nature à compromettre son indépendance.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
